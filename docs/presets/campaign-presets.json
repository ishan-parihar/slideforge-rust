{
  "_meta": {
    "version": "1.0.0",
    "description": "SlideForge Campaign Presets — dynamic slide-type arrays for AI-agent carousel generation",
    "usage": "AI agent selects a preset, fills in {{variables}} with content from the user's brief, and generates the carousel via the slideforge MCP/render-carousel pipeline.",
    "rhythm_principles": [
      "Never repeat the same slide_type consecutively",
      "Alternate dark/light bg_style for visual contrast (DLD pattern: Dark-Light-Dark)",
      "Hook → Context → Evidence → Proof → Action arc",
      "Dense data slides alternate with sparse narrative slides",
      "Image slides break text-heavy sequences",
      "CTA is always the final slide"
    ],
    "slide_type_vocabulary": {
      "opening": ["hero", "image_headline", "section_divider", "headline_subheadline", "image_caption"],
      "narrative": ["definition", "text_block", "problem_solution", "myth_fact", "before_after_story", "timeline", "process_map"],
      "data": ["chart", "column_chart", "scatter_plot", "gauge", "radar_chart", "progress_rings", "comparison_bars", "metric_grid", "metric_card", "funnel_chart", "stat_row", "table"],
      "social_proof": ["testimonial_avatar", "logo_cloud", "case_study_result", "faq"],
      "visual": ["image_caption", "image_headline", "image_quote", "image_callout", "image_gallery", "image_collage", "image_comparison", "image_stat"],
      "feature": ["feature", "grid_cards", "split_features", "list", "checklist_action_plan"],
      "closing": ["cta", "qr_destination", "pricing_plan"]
    }
  },

  "presets": [
    {
      "id": "product_launch",
      "name": "Product Launch",
      "description": "Announce a new product or major feature release. Hook with impact, explain the problem it solves, show proof it works, close with access.",
      "ideal_slide_count": "8-10",
      "rhythm": "Hero → Problem → Solution → Features → Proof → CTA",
      "theme_preferences": {"primary": "bold", "secondary": "editorial"},
      "slides": [
        {
          "slot": "opening_hook",
          "required": true,
          "slide_type": "hero",
          "theme": "bold",
          "bg_style": "dark",
          "archetype": "thought_leader",
          "params_template": {
            "headline": "{{product_name}}",
            "subheadline": "{{one_line_value_prop}}",
            "badge": "{{launch_badge}}"
          }
        },
        {
          "slot": "problem_context",
          "required": true,
          "slide_type": "problem_solution",
          "theme": "editorial",
          "bg_style": "light",
          "archetype": "educator",
          "params_template": {
            "title": "{{problem_title}}",
            "problem": "{{problem_statement}}",
            "solution": "{{solution_statement}}",
            "proof_points": "{{proof_points}}"
          }
        },
        {
          "slot": "feature_grid",
          "required": true,
          "slide_type": "grid_cards",
          "theme": "editorial",
          "bg_style": "dark",
          "archetype": "data_analyst",
          "variant": "dense",
          "params_template": {
            "title": "{{features_title}}",
            "cards": "{{feature_cards}}"
          }
        },
        {
          "slot": "social_proof",
          "required": false,
          "slide_type": "testimonial_avatar",
          "theme": "editorial",
          "bg_style": "light",
          "archetype": "thought_leader",
          "params_template": {
            "quote": "{{testimonial_quote}}",
            "author": "{{testimonial_author}}",
            "role": "{{testimonial_role}}",
            "avatar_url": "{{avatar_url}}"
          }
        },
        {
          "slot": "metric_proof",
          "required": false,
          "slide_type": "metric_grid",
          "theme": "bold",
          "bg_style": "dark",
          "archetype": "data_analyst",
          "params_template": {
            "title": "{{metrics_title}}",
            "metrics": "{{key_metrics}}"
          }
        },
        {
          "slot": "closing_cta",
          "required": true,
          "slide_type": "cta",
          "theme": "bold",
          "bg_style": "dark",
          "archetype": "startup_pitch",
          "params_template": {
            "headline": "{{cta_headline}}",
            "button_text": "{{cta_button_text}}",
            "button_url": "{{cta_url}}",
            "subtext": "{{cta_subtext}}"
          }
        }
      ]
    },

