    "html": "<div style=\"position:relative;width:100%;height:100%;background:radial-gradient(at 40% 20%, #B71C1C15 0px, transparent 50%), radial-gradient(at 80% 0%, #007C9A10 0px, transparent 50%), radial-gradient(at 0% 50%, #FF877812 0px, transparent 50%), var(--surface-light);background-color:var(--surface-light);overflow:hidden;\">\n            <div style=\"background: var(--texture-grain); opacity: 0.04; position: absolute; pointer-events: none; inset: 0; z-index: 1\"></div>\n            \n            <div class=\"slide-content\" style=\"position:relative;z-index:10;padding:80px 48px var(--space-12);display:flex;flex-direction:column;justify-content:center;height:100%;width:100%;box-sizing:border-box;overflow:hidden;\">\n                <div style=\"max-width:320px;margin:0 auto;text-align:left;width:100%;box-sizing:border-box;display:flex;flex-direction:column;justify-content:center;height:100%;overflow:hidden;padding-bottom:var(--space-2);\">\n            <h2 style=\"font-family:Plus Jakarta Sans;font-size:22px;font-weight:700;color:#0F0A09;margin:0 0 16px;line-height:1.2;\">What We Lost</h2>\n            <div style=\"margin-top:4px;\"><p style=\"font-family:Plus Jakarta Sans;font-size:14px;color:#4A3F3E;margin:0 0 12px;line-height:1.6;\">The serendipity. Finding a random blog at 2am that changed how you thought about everything. The intimacy. Knowing the person behind the website. The patience. Reading 5,000 words because the writing was that good.</p></div>\n        </div>\n            </div>\n        </div>",
