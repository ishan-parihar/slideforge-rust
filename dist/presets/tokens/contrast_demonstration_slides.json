    "html": "<div style=\"position:relative;width:100%;height:100%;background:radial-gradient(at 40% 20%, #CD380115 0px, transparent 50%), radial-gradient(at 80% 0%, #008BBC10 0px, transparent 50%), radial-gradient(at 0% 50%, #FFA17712 0px, transparent 50%), var(--surface-light);background-color:var(--surface-light);overflow:hidden;\">\n            <div style=\"position: absolute; inset: 0; background: var(--texture-grain); opacity: 0.04; z-index: 1; pointer-events: none\"></div>\n            \n            <div class=\"slide-content\" style=\"position:relative;z-index:10;padding:80px var(--space-6) 80px;display:flex;flex-direction:column;justify-content:center;height:100%;width:100%;box-sizing:border-box;overflow:hidden;\">\n                <h2 style=\"font-family: Plus Jakarta Sans; font-size: 25px; font-weight: 600; line-height: 1.12; color: #0F0A08; margin: 0 0 12px; text-align: left; letter-spacing: -0.015em; overflow-wrap: break-word\">The Nexus Way</h2><div style=\"margin-top:12px;\"><div style=\"display:flex;align-items:flex-start;margin-bottom:6px;gap:4px;\">\n                        <span style=\"color:#CD3801;margin-right:8px;font-size:11px;line-height:1.3;flex-shrink:0;\">\u2726</span>\n                        <div style=\"flex:1;min-width:0;\">\n                            <div style=\"font-family:Plus Jakarta Sans;font-size:12px;font-weight:600;color:#0F0A08;line-height:1.25;\">Write one sentence: &#x27;Launch carousel for our new API product.&#x27;</div>\n                            \n                        </div>\n                    </div><div style=\"display:flex;align-items:flex-start;margin-bottom:6px;gap:4px;\">\n                        <span style=\"color:#CD3801;margin-right:8px;font-size:11px;line-height:1.3;flex-shrink:0;\">\u2726</span>\n                        <div style=\"flex:1;min-width:0;\">\n                            <div style=\"font-family:Plus Jakarta Sans;font-size:12px;font-weight:600;color:#0F0A08;line-height:1.25;\">Nexus generates 10 slides with emotional arc, theme, and content.</div>\n                            \n                        </div>\n                    </div><div style=\"display:flex;align-items:flex-start;margin-bottom:6px;gap:4px;\">\n                        <span style=\"color:#CD3801;margin-right:8px;font-size:11px;line-height:1.3;flex-shrink:0;\">\u2726</span>\n                        <div style=\"flex:1;min-width:0;\">\n                            <div style=\"font-family:Plus Jakarta Sans;font-size:12px;font-weight:600;color:#0F0A08;line-height:1.25;\">Review. Tweak one headline. Done.</div>\n                            \n                        </div>\n                    </div><div style=\"display:flex;align-items:flex-start;margin-bottom:6px;gap:4px;\">\n                        <span style=\"color:#CD3801;margin-right:8px;font-size:11px;line-height:1.3;flex-shrink:0;\">\u2726</span>\n                        <div style=\"flex:1;min-width:0;\">\n                            <div style=\"font-family:Plus Jakarta Sans;font-size:12px;font-weight:600;color:#0F0A08;line-height:1.25;\">Export to PNG or HTML. Ship.</div>\n                            \n                        </div>\n                    </div><div style=\"display:flex;align-items:flex-start;margin-bottom:6px;gap:4px;\">\n                        <span style=\"color:#CD3801;margin-right:8px;font-size:11px;line-height:1.3;flex-shrink:0;\">\u2726</span>\n                        <div style=\"flex:1;min-width:0;\">\n                            <div style=\"font-family:Plus Jakarta Sans;font-size:12px;font-weight:600;color:#0F0A08;line-height:1.25;\">Total time: 4 minutes. Total cost: $0.</div>\n                            \n                        </div>\n                    </div></div>\n            </div>\n        </div>",
