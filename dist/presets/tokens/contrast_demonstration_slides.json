    "html": "<div style=\"position:relative;width:100%;height:100%;background:radial-gradient(at 40% 20%, #CD380115 0px, transparent 50%), radial-gradient(at 80% 0%, #008BBC10 0px, transparent 50%), radial-gradient(at 0% 50%, #FFA17712 0px, transparent 50%), var(--surface-light);background-color:var(--surface-light);overflow:hidden;\">\n            <div style=\"opacity: 0.04; position: absolute; inset: 0; pointer-events: none; z-index: 1; background: var(--texture-grain)\"></div>\n            \n            <div class=\"slide-content\" style=\"position:relative;z-index:10;padding:80px var(--space-6) 80px;display:flex;flex-direction:column;justify-content:center;height:100%;width:100%;box-sizing:border-box;overflow:hidden;\">\n                <div style=\"background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);backdrop-filter:var(--glass-dark-blur);-webkit-backdrop-filter:var(--glass-dark-blur);border-radius:10px;padding:var(--space-8);\"><h2 style=\"font-family: Plus Jakarta Sans; font-size: 25px; font-weight: 600; line-height: 1.12; color: #F5ECEA; margin: 0 0 12px; text-align: left; letter-spacing: -0.015em; overflow-wrap: break-word\">Side by Side</h2><div style=\"display:grid;grid-template-columns:1fr 1fr 1fr ;margin-top:16px;width:100%;box-sizing:border-box;align-items:stretch;\">\n                    <div style=\"font-family:Plus Jakarta Sans;font-size:20px;font-weight:700;color:#F5ECEA;padding:12px 16px;border-bottom:1px solid #D4C7C420;display:flex;align-items:center;min-height:42px;box-sizing:border-box;\">Feature</div><div style=\"font-family:Plus Jakarta Sans;font-size:20px;font-weight:700;color:#F5ECEA;padding:12px 16px;border-bottom:1px solid #D4C7C420;display:flex;align-items:center;min-height:42px;box-sizing:border-box;\">Manual Design</div><div style=\"font-family:Plus Jakarta Sans;font-size:20px;font-weight:700;color:#F5ECEA;padding:12px 16px;border-bottom:1px solid #D4C7C420;display:flex;align-items:center;min-height:42px;box-sizing:border-box;\">Nexus Composition</div><div style=\"font-family:Plus Jakarta Sans;font-size:16px;color:#F5ECEA;padding:12px 16px;border-bottom:1px solid #D4C7C420;display:flex;align-items:center;min-height:42px;box-sizing:border-box;\">Time per slide</div><div style=\"font-family:Plus Jakarta Sans;font-size:16px;color:#F5ECEA;padding:12px 16px;border-bottom:1px solid #D4C7C420;display:flex;align-items:center;min-height:42px;box-sizing:border-box;\">Hours</div><div style=\"font-family:Plus Jakarta Sans;font-size:16px;color:#F5ECEA;padding:12px 16px;border-bottom:1px solid #D4C7C420;display:flex;align-items:center;min-height:42px;box-sizing:border-box;\">Seconds</div><div style=\"font-family:Plus Jakarta Sans;font-size:16px;color:#F5ECEA;padding:12px 16px;border-bottom:1px solid #D4C7C420;display:flex;align-items:center;min-height:42px;box-sizing:border-box;\">Branding</div><div style=\"font-family:Plus Jakarta Sans;font-size:16px;color:#F5ECEA;padding:12px 16px;border-bottom:1px solid #D4C7C420;display:flex;align-items:center;min-height:42px;box-sizing:border-box;\">Inconsistent</div><div style=\"font-family:Plus Jakarta Sans;font-size:16px;color:#F5ECEA;padding:12px 16px;border-bottom:1px solid #D4C7C420;display:flex;align-items:center;min-height:42px;box-sizing:border-box;\">Locked system</div><div style=\"font-family:Plus Jakarta Sans;font-size:16px;color:#F5ECEA;padding:12px 16px;border-bottom:1px solid #D4C7C420;display:flex;align-items:center;min-height:42px;box-sizing:border-box;\">Export</div><div style=\"font-family:Plus Jakarta Sans;font-size:16px;color:#F5ECEA;padding:12px 16px;border-bottom:1px solid #D4C7C420;display:flex;align-items:center;min-height:42px;box-sizing:border-box;\">Format breaks</div><div style=\"font-family:Plus Jakarta Sans;font-size:16px;color:#F5ECEA;padding:12px 16px;border-bottom:1px solid #D4C7C420;display:flex;align-items:center;min-height:42px;box-sizing:border-box;\">Pixel-perfect</div><div style=\"font-family:Plus Jakarta Sans;font-size:16px;color:#F5ECEA;padding:12px 16px;border-bottom:1px solid #D4C7C420;display:flex;align-items:center;min-height:42px;box-sizing:border-box;\">Stakeholders</div><div style=\"font-family:Plus Jakarta Sans;font-size:16px;color:#F5ECEA;padding:12px 16px;border-bottom:1px solid #D4C7C420;display:flex;align-items:center;min-height:42px;box-sizing:border-box;\">Bottleneck</div><div style=\"font-family:Plus Jakarta Sans;font-size:16px;color:#F5ECEA;padding:12px 16px;border-bottom:1px solid #D4C7C420;display:flex;align-items:center;min-height:42px;box-sizing:border-box;\">One-click</div>\n                </div></div>\n            </div>\n        </div>",
