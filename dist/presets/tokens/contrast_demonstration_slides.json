    "html": "<div style=\"position:relative;width:100%;height:100%;background:var(--surface-dark);background-color:var(--surface-dark);overflow:hidden;\">\n            <div style=\"position: absolute; pointer-events: none; background: var(--texture-grain); opacity: 0.04; inset: 0; z-index: 1\"></div>\n            \n            <div class=\"slide-content\" style=\"position:relative;z-index:10;padding:80px 48px 80px;display:flex;flex-direction:column;justify-content:center;height:100%;width:100%;box-sizing:border-box;overflow:hidden;\">\n                <div style=\"text-align: center; max-width: 500px; margin: 0 auto; width:100%; position:relative; z-index:3;\">\n            <span style=\"background: linear-gradient(135deg, #FFFFFF 0%, #F5ECEA 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; font-family: Plus Jakarta Sans; font-size: 31px; font-weight: 600; line-height: 1.08; text-align: center; margin: 0 0 16px; display: block; letter-spacing: -0.02em\">Manual Design vs. Nexus Composition</span>\n            <div style=\"width: 60px; height: 3.5px; background: #EA542B; margin: 24px auto; border-radius: 2px; box-shadow: 0 2px 10px #EA542B40;\"></div>\n            <p style=\"font-family:Plus Jakarta Sans;font-size:15px;color:#D7CBC7;margin:0;line-height:1.6;font-weight:400;text-wrap:balance;text-shadow:0 1px 2px rgba(0,0,0,0.05);\">Same goal. Radically different outcomes.</p>\n        </div>\n            </div>\n        </div>",
