    "html": "<div style=\"position:relative;width:100%;height:100%;background:radial-gradient(at 40% 20%, #CD380115 0px, transparent 50%), radial-gradient(at 80% 0%, #008BBC10 0px, transparent 50%), radial-gradient(at 0% 50%, #FFA17712 0px, transparent 50%), var(--surface-light);background-color:var(--surface-light);overflow:hidden;\">\n            <div style=\"position: absolute; opacity: 0.04; pointer-events: none; z-index: 1; inset: 0; background: var(--texture-grain)\"></div>\n            \n            <div class=\"slide-content\" style=\"position:relative;z-index:10;padding:80px var(--space-6) 80px;display:flex;flex-direction:column;justify-content:center;height:100%;width:100%;box-sizing:border-box;overflow:hidden;\">\n                <div style=\"width:100%;height:100%;display:flex;flex-direction:column;justify-content:center;align-items:center;gap:6px;\">\n            <h2 style=\"font-family: Plus Jakarta Sans; font-size: 25px; font-weight: 600; line-height: 1.12; color: #F5ECEA; margin: 0 0 8px; text-align: center; letter-spacing: -0.015em; overflow-wrap: break-word\">Visual Difference</h2>\n            <div style=\"position:relative;width:100%;height:215px;display:grid;grid-template-columns:1fr 1fr;gap:2px;border-radius:var(--radius-md) var(--radius-lg) var(--radius-md) var(--radius-lg);overflow:hidden;box-shadow:0 4px 6px -1px rgba(0,0,0,0.08), 0 2px 4px -2px rgba(0,0,0,0.05);border: 1px solid #3B292330;background:#3B292320;\">\n                <div style=\"position:relative;width:100%;height:100%;\">\n                    <div style=\"position:relative;width:100%;height:100%;border-radius: 0;overflow:hidden;background:transparent;box-sizing:border-box;\">\n                <img src=\"https://images.unsplash.com/photo-1519389950473-47ba0277781c?w=600\" alt=\"Before\" style=\"display:block;width:100%;height:100%;object-fit: cover; object-position: center;filter: contrast(1.06) brightness(1.06);\" />\n                \n            </div>\n                    <span style=\"background:rgba(0,0,0,0.7);backdrop-filter:blur(4px);-webkit-backdrop-filter:blur(4px);color:white;padding:4px 8px;font-family:Plus Jakarta Sans;font-size:9.5px;font-weight:700;border-radius:4px;position:absolute;top:10px;z-index:3;text-transform:uppercase;letter-spacing:0.06em;left:10px;\">Before</span>\n                </div>\n                <div style=\"position:relative;width:100%;height:100%;\">\n                    <div style=\"position:relative;width:100%;height:100%;border-radius: 0;overflow:hidden;background:transparent;box-sizing:border-box;\">\n                <img src=\"https://images.unsplash.com/photo-1460925895917-afdab827c52f?w=600\" alt=\"After\" style=\"display:block;width:100%;height:100%;object-fit: cover; object-position: center;filter: contrast(1.06) brightness(1.06);\" />\n                \n            </div>\n                    <span style=\"background:rgba(0,0,0,0.7);backdrop-filter:blur(4px);-webkit-backdrop-filter:blur(4px);color:white;padding:4px 8px;font-family:Plus Jakarta Sans;font-size:9.5px;font-weight:700;border-radius:4px;position:absolute;top:10px;z-index:3;text-transform:uppercase;letter-spacing:0.06em;right:10px;\">After</span>\n                </div>\n                <div style=\"position:absolute;left:50%;top:0;bottom:0;width:2px;background:white;z-index:4;box-shadow:0 0 8px rgba(0,0,0,0.4);transform:translateX(-50%);\"></div>\n            </div>\n            <p style=\"font-family:Plus Jakarta Sans;font-size:11px;color:#D7CBC7;margin:4px 0 0;line-height:1.4;text-align:center;width:100%;opacity:0.85;\">Stock template vs on-brand composition</p>\n        </div>\n            </div>\n        </div>",
