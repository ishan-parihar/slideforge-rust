lay:flex;justify-content:space-between;align-items:center;margin-top:10px;font-family:Plus Jakarta Sans;font-size:15px;font-weight:800;letter-spacing:-0.01em;line-height:1.2;\">\n                <span style=\"color:#EA542B;text-align:left;white-space:nowrap;flex-shrink:0;\">15 Time to First Carousel</span>\n                <span style=\"color:#D7CBC7;text-align:right;white-space:nowrap;flex-shrink:0;\">95 Time to First Carousel</span>\n            </div>\n        </div>\n        </div>\n            </div>\n        </div>",
