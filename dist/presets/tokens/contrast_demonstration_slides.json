    "html": "<div style=\"position:relative;width:100%;height:100%;background:var(--surface-dark);background-color:var(--surface-dark);overflow:hidden;\">\n            <div style=\"pointer-events: none; background: var(--texture-grain); position: absolute; z-index: 1; inset: 0; opacity: 0.04\"></div>\n            \n            <div class=\"slide-content\" style=\"position:relative;z-index:10;padding:80px var(--space-6) 80px;display:flex;flex-direction:column;justify-content:center;height:100%;width:100%;box-sizing:border-box;overflow:hidden;\">\n                <h2 style=\"font-family: Plus Jakarta Sans; font-size: 25px; font-weight: 600; line-height: 1.12; color: #F5ECEA; margin: 0 0 12px; text-align: left; letter-spacing: -0.015em; overflow-wrap: break-word\">The Manual Way</h2><div style=\"margin-top:12px;\"><div style=\"display:flex;align-items:flex-start;margin-bottom:6px;gap:4px;\">\n                        <span style=\"color:#CD3801;margin-right:8px;font-size:11px;line-height:1.3;flex-shrink:0;\">\u2726</span>\n                        <div style=\"flex:1;min-width:0;\">\n                            <div style=\"font-family:Plus Jakarta Sans;font-size:12px;font-weight:600;color:#F5ECEA;line-height:1.25;\">Open Figma. Find the template. Hope it still exists.</div>\n                            \n                        </div>\n                    </div><div style=\"display:flex;align-items:flex-start;margin-bottom:6px;gap:4px;\">\n                        <span style=\"color:#CD3801;margin-right:8px;font-size:11px;line-height:1.3;flex-shrink:0;\">\u2726</span>\n                        <div style=\"flex:1;min-width:0;\">\n                            <div style=\"font-family:Plus Jakarta Sans;font-size:12px;font-weight:600;color:#F5ECEA;line-height:1.25;\">Pick colors. Argue about brand compliance. Redo it.</div>\n                            \n                        </div>\n                    </div><div style=\"display:flex;align-items:flex-start;margin-bottom:6px;gap:4px;\">\n                        <span style=\"color:#CD3801;margin-right:8px;font-size:11px;line-height:1.3;flex-shrink:0;\">\u2726</span>\n                        <div style=\"flex:1;min-width:0;\">\n                            <div style=\"font-family:Plus Jakarta Sans;font-size:12px;font-weight:600;color:#F5ECEA;line-height:1.25;\">Write copy in Google Docs. Paste into Figma. Formatting breaks.</div>\n                            \n                        </div>\n                    </div><div style=\"display:flex;align-items:flex-start;margin-bottom:6px;gap:4px;\">\n                        <span style=\"color:#CD3801;margin-right:8px;font-size:11px;line-height:1.3;flex-shrink:0;\">\u2726</span>\n                        <div style=\"flex:1;min-width:0;\">\n                            <div style=\"font-family:Plus Jakarta Sans;font-size:12px;font-weight:600;color:#F5ECEA;line-height:1.25;\">Export. Realize slide 7 is cut off. Fix. Re-export.</div>\n                            \n                        </div>\n                    </div><div style=\"display:flex;align-items:flex-start;margin-bottom:6px;gap:4px;\">\n                        <span style=\"color:#CD3801;margin-right:8px;font-size:11px;line-height:1.3;flex-shrink:0;\">\u2726</span>\n                        <div style=\"flex:1;min-width:0;\">\n                            <div style=\"font-family:Plus Jakarta Sans;font-size:12px;font-weight:600;color:#F5ECEA;line-height:1.25;\">Send to 3 stakeholders. Wait for feedback. Get conflicting notes.</div>\n                            \n                        </div>\n                    </div><div style=\"display:flex;align-items:flex-start;margin-bottom:6px;gap:4px;\">\n                        <span style=\"color:#CD3801;margin-right:8px;font-size:11px;line-height:1.3;flex-shrink:0;\">\u2726</span>\n                        <div style=\"flex:1;min-width:0;\">\n                            <div style=\"font-family:Plus Jakarta Sans;font-size:12px;font-weight:600;color:#F5ECEA;line-height:1.25;\">Redo slides 2, 5, and 7. Export again. Ship 3 days late.</div>\n                            \n                        </div>\n                    </div></div>\n            </div>\n        </div>",
