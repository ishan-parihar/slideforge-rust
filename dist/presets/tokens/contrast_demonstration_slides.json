    "html": "<div style=\"position:relative;width:100%;height:100%;background:var(--surface-dark);background-color:var(--surface-dark);overflow:hidden;\">\n            <div style=\"opacity: 0.04; background: var(--texture-grain); pointer-events: none; position: absolute; z-index: 1; inset: 0\"></div>\n            \n            <div class=\"slide-content\" style=\"position:relative;z-index:10;padding:72px 44px;display:flex;flex-direction:column;justify-content:center;height:100%;width:100%;box-sizing:border-box;overflow:hidden;\">\n                <div style=\"width:100%;display:flex;flex-direction:column;gap:18px;\">\n            <h2 style=\"font-family:Plus Jakarta Sans;font-size:28px;font-weight:900;color:#F5ECEA;margin:0;line-height:1.08;\">The Real Cost</h2>\n            <div style=\"display:grid;grid-template-columns:1fr auto 1fr;gap:var(--space-1);align-items:stretch;\">\n                <div style=\"border-radius:0;padding:16px;background:rgba(255,255,255,0.06);border:1px solid #3B2923;box-sizing:border-box;\">\n                    <div style=\"font-family:Plus Jakarta Sans;font-size:11px;font-weight:900;color:#EF4444;margin-bottom:8px;letter-spacing:0.06em;\">BEFORE</div>\n                    <p style=\"font-family:Plus Jakarta Sans;font-size:var(--text-sm);color:#D7CBC7;line-height:1.45;margin:0;\">Manual Process: 12 hours per carousel \u00d7 4 carousels/week \u00d7 $75/hr = $18,000/month in design labor</p>\n                </div>\n                <div style=\"display:flex;align-items:center;justify-content:center;color:#ED582E;font-family:Plus Jakarta Sans;font-size:22px;font-weight:900;\">\u2192</div>\n                <div style=\"border-radius:0;padding:16px;background:rgba(255,255,255,0.06);border:1px solid #3B2923;box-sizing:border-box;\">\n                    <div style=\"font-family:Plus Jakarta Sans;font-size:11px;font-weight:900;color:#ED582E;margin-bottom:8px;letter-spacing:0.06em;\">AFTER</div>\n                    <p style=\"font-family:Plus Jakarta Sans;font-size:var(--text-sm);color:#D7CBC7;line-height:1.45;margin:0;\">Nexus Pipeline: 4 minutes per carousel \u00d7 4 carousels/week \u00d7 $0 = effectively free, with better consistency</p>\n                </div>\n            </div>\n            <div style=\"margin-top:14px;border-radius:0;background:rgba(255,255,255,0.06);border:1px solid #3B2923;padding:var(--space-2) 16px;\">\n                <div style=\"font-family:Plus Jakarta Sans;font-size:11px;font-weight:900;color:#ED582E;letter-spacing:0.06em;margin-bottom:6px;\">Saved in Design Costs</div>\n                <div style=\"font-family:Plus Jakarta Sans;font-size:var(--text-lg);font-weight:800;color:#F5ECEA;line-height:1.2;\">$18K/mo</div>\n            </div>\n        </div>\n            </div>\n        </div>",
