    "html": "<div style=\"position:relative;width:100%;height:100%;background:var(--surface-dark);background-color:var(--surface-dark);overflow:hidden;\">\n            <div style=\"z-index: 1; inset: 0; position: absolute; opacity: 0.04; pointer-events: none; background: var(--texture-grain)\"></div>\n            \n            <div class=\"slide-content--bleed\" style=\"position:relative;z-index:10;padding:0;display:flex;flex-direction:column;justify-content:stretch;height:100%;width:100%;box-sizing:border-box;overflow:hidden;\">\n                <div style=\"position:relative;width:100%;height:100%;\">\n            <div style=\"position:relative;width:100%;height:100%;border-radius: 0;overflow:hidden;background:transparent;box-sizing:border-box;\">\n                <img src=\"https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=600\" alt=\"They Said It Couldn&#x27;t Be Done in Rust\" style=\"display:block;width:100%;height:100%;object-fit: cover; object-position: center;filter: contrast(1.06) brightness(1.06);\" />\n                <div style=\"position:absolute;inset:0;background:linear-gradient(to bottom, rgba(0,0,0,0.15), rgba(0,0,0,0.68));z-index:2;\"></div>\n            </div>\n            <div style=\"position:absolute;inset:0;padding:60px 28px;display:flex;flex-direction:column;justify-content:flex-end;z-index:3;\">\n                <h2 style=\"font-family:Plus Jakarta Sans;font-size:32px;font-weight:800;color:white;margin:0;line-height:1.15;letter-spacing:-0.02em;text-shadow:0 2px 10px rgba(0,0,0,0.7);\">They Said It Couldn&#x27;t Be Done in Rust</h2>\n                <p style=\"font-family:Plus Jakarta Sans;font-size:13.5px;color:rgba(255,255,255,0.88);margin:10px 0 0;line-height:1.45;text-shadow:0 2px 8px rgba(0,0,0,0.6);\">A slide engine in Rust? With HTML rendering? The experts gave it six months.</p>\n            </div>\n        </div>\n            </div>\n        </div>",
