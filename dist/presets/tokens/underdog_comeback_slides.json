    "html": "<div style=\"position:relative;width:100%;height:100%;background:var(--surface-dark);background-color:var(--surface-dark);overflow:hidden;\">\n            <div style=\"background: var(--texture-grain); opacity: 0.04; pointer-events: none; z-index: 1; position: absolute; inset: 0\"></div>\n            \n            <div class=\"slide-content\" style=\"position:relative;z-index:10;padding:80px var(--space-6) 80px;display:flex;flex-direction:column;justify-content:center;height:100%;width:100%;box-sizing:border-box;overflow:hidden;\">\n                <div style=\"width:100%;display:flex;flex-direction:column;gap:12px;\">\n            <h2 style=\"font-family: Plus Jakarta Sans; font-size: 25px; font-weight: 600; line-height: 1.12; color: #ECEEF5; margin: 0 0 12px; text-align: left; letter-spacing: -0.015em; overflow-wrap: break-word\">The Grind \u2014 547 Days</h2>\n            <div style=\"display:grid;grid-template-columns:1fr 1fr;gap:12px;width:100%;\"><div style=\"background:rgba(255,255,255,0.05);border:1px solid #282D3D;border-radius:0;padding:16px 14px;box-sizing:border-box;display:flex;flex-direction:column;gap:6px;position:relative;\">\n                <div style=\"display:flex;align-items:center;justify-content:space-between;width:100%;\">\n                    <span style=\"font-family:Plus Jakarta Sans;font-size:10px;font-weight:800;color:#CACDD8;text-transform:uppercase;letter-spacing:0.06em;\">tests passing after 547 days of continuous development</span>\n                    <span style=\"font-size:10px;font-weight:900;color:#EF4444;background:#EF444418;padding:2px 6px;border-radius:4px;margin-left:auto;\">0 failures</span>\n                </div>\n                <div style=\"font-family:Plus Jakarta Sans;font-size:30px;font-weight:900;color:#6781E4;line-height:1;\">85</div>\n                <div style=\"width:100%;height:3px;background:#6781E420;border-radius:999px;margin-top:2px;overflow:hidden;\">\n                    <div style=\"width:75%;height:100%;background:#6781E4;border-radius:999px;\"></div>\n                </div>\n            </div></div>\n            <p style=\"font-family:Plus Jakarta Sans;font-size:10.5px;color:#CACDD8;margin:4px 0 0;line-height:1.4;opacity:0.85;\">Real-time performance telemetry metrics sampled across production worker threads.</p>\n        </div>\n            </div>\n        </div>",
