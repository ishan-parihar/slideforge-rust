    "html": "<div style=\"position:relative;width:100%;height:100%;background:radial-gradient(at 40% 20%, #1A237E15 0px, transparent 50%), radial-gradient(at 80% 0%, #50290010 0px, transparent 50%), radial-gradient(at 0% 50%, #5F78DA12 0px, transparent 50%), var(--surface-light);background-color:var(--surface-light);overflow:hidden;\">\n            <div style=\"position: absolute; background: var(--texture-grain); pointer-events: none; opacity: 0.04; inset: 0; z-index: 1\"></div>\n            \n            <div class=\"slide-content\" style=\"position:relative;z-index:10;padding:72px 44px;display:flex;flex-direction:column;justify-content:center;height:100%;width:100%;box-sizing:border-box;overflow:hidden;\">\n                <div style=\"width:100%;display:flex;flex-direction:column;gap:18px;\">\n            <h2 style=\"font-family:Plus Jakarta Sans;font-size:28px;font-weight:900;color:#090B0F;margin:0;line-height:1.08;\">The Full Arc</h2>\n            <div style=\"display:grid;grid-template-columns:1fr auto 1fr;gap:var(--space-1);align-items:stretch;\">\n                <div style=\"border-radius:0;padding:16px;background:rgba(255,255,255,0.92);border:1px solid #C3C7D1;box-sizing:border-box;\">\n                    <div style=\"font-family:Plus Jakarta Sans;font-size:11px;font-weight:900;color:#EF4444;margin-bottom:8px;letter-spacing:0.06em;\">BEFORE</div>\n                    <p style=\"font-family:Plus Jakarta Sans;font-size:var(--text-sm);color:#3F424B;line-height:1.45;margin:0;\">Day 1: Zero stars. Zero users. Zero credibility. A conviction that Rust could build something beautiful.</p>\n                </div>\n                <div style=\"display:flex;align-items:center;justify-content:center;color:#1A237E;font-family:Plus Jakarta Sans;font-size:22px;font-weight:900;\">\u2192</div>\n                <div style=\"border-radius:0;padding:16px;background:rgba(255,255,255,0.92);border:1px solid #C3C7D1;box-sizing:border-box;\">\n                    <div style=\"font-family:Plus Jakarta Sans;font-size:11px;font-weight:900;color:#1A237E;margin-bottom:8px;letter-spacing:0.06em;\">AFTER</div>\n                    <p style=\"font-family:Plus Jakarta Sans;font-size:var(--text-sm);color:#3F424B;line-height:1.45;margin:0;\">Day 547: 85 tests. 47 slide types. 28 presets. A tool that generates production carousels in under a second.</p>\n                </div>\n            </div>\n            <div style=\"margin-top:14px;border-radius:0;background:rgba(255,255,255,0.92);border:1px solid #C3C7D1;padding:var(--space-2) 16px;\">\n                <div style=\"font-family:Plus Jakarta Sans;font-size:11px;font-weight:900;color:#1A237E;letter-spacing:0.06em;margin-bottom:6px;\">From Zero to Shipped</div>\n                <div style=\"font-family:Plus Jakarta Sans;font-size:var(--text-lg);font-weight:800;color:#090B0F;line-height:1.2;\">547 days</div>\n            </div>\n        </div>\n            </div>\n        </div>",
