    "html": "<div style=\"position:relative;width:100%;height:100%;background:var(--surface-dark);background-color:var(--surface-dark);overflow:hidden;\">\n            <div style=\"inset: 0; background: var(--texture-grain); pointer-events: none; z-index: 1; position: absolute; opacity: 0.04\"></div>\n            <div style=\"position:absolute;inset:0;overflow:hidden;pointer-events:none;z-index:1;\"><div style=\"pointer-events: none; opacity: 0.07; top: -80px; left: -80px; width: 320px; position: absolute; background: #5E5FE0; height: 320px; border-radius: 50%\"></div><div style=\"background: #937000; position: absolute; left: auto; opacity: 0.05; right: -40px; width: 120px; height: 120px; transform: rotate(60deg); border-radius: 4px; pointer-events: none; top: 60%\"></div></div>\n            <div class=\"slide-content\" style=\"position:relative;z-index:10;padding:80px var(--space-6) 80px;display:flex;flex-direction:column;justify-content:center;height:100%;width:100%;box-sizing:border-box;overflow:hidden;\">\n                <div style=\"background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);backdrop-filter:var(--glass-dark-blur);-webkit-backdrop-filter:var(--glass-dark-blur);border-radius:10px;padding:var(--space-8);\"><div style=\"display: inline-block; padding: 6px 16px; background: #7478FC15; border: 1px solid #7478FC30; border-radius: 9999px; font-family: DM Sans; font-size: 13px; font-weight: 600; color: #7478FC; letter-spacing: 0.05em; text-transform: uppercase; margin: 0 0 16px;\">JUST SHIPPED</div><span style=\"background: linear-gradient(135deg, #FFFFFF 0%, #EDEEF5 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; font-family: Playfair Display; font-size: 31px; font-weight: 600; line-height: 1.08; text-align: left; margin: 0; display: block; letter-spacing: -0.02em\">Introducing Nexus 3.0</span><p style=\"font-family: DM Sans; font-size: 16px; font-weight: 400; line-height: 1.55; color: #CBCDD8; margin: 8px 0 0; text-align: left\">The slide engine that writes itself. Describe what you need. Nexus builds the carousel.</p></div>\n            </div>\n        </div>",
