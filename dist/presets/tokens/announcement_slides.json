4px;box-sizing:border-box;display:flex;flex-direction:column;gap:6px;position:relative;\">\n                <div style=\"display:flex;align-items:center;justify-content:space-between;width:100%;\">\n                    <span style=\"font-family:DM Sans;font-size:10px;font-weight:800;color:#CBCDD8;text-transform:uppercase;letter-spacing:0.06em;\">Slide compositions</span>\n                    \n                </div>\n                <div style=\"font-family:Playfair Display;font-size:30px;font-weight:900;color:#7478FC;line-height:1;\">144+</div>\n                <div style=\"width:100%;height:3px;background:#7478FC20;border-radius:999px;margin-top:2px;overflow:hidden;\">\n                    <div style=\"width:75%;height:100%;background:#7478FC;border-radius:999px;\"></div>\n                </div>\n            </div><div style=\"background:rgba(255,255,255,0.05);border:1px solid #2A2C3D;border-radius:0;padding:16px 14px;box-sizing:border-box;display:flex;flex-direction:column;gap:6px;position:relative;\">\n                <div style=\"display:flex;align-items:center;justify-content:space-between;width:100%;\">\n                    <span style=\"font-family:DM Sans;font-size:10px;font-weight:800;color:#CBCDD8;text-transform:uppercase;letter-spacing:0.06em;\">Campaign presets</span>\n                    \n                </div>\n                <div style=\"font-family:Playfair Display;font-size:30px;font-weight:900;color:#7478FC;line-height:1;\">28</div>\n                <div style=\"width:100%;height:3px;background:#7478FC20;border-radius:999px;margin-top:2px;overflow:hidden;\">\n                    <div style=\"width:75%;height:100%;background:#7478FC;border-radius:999px;\"></div>\n                </div>\n            </div><div style=\"background:rgba(255,255,255,0.05);border:1px solid #2A2C3D;border-radius:0;padding:16px 14px;box-sizing:border-box;display:flex;flex-direction:column;gap:6px;position:relative;\">\n                <div style=\"display:flex;align-items:center;justify-content:space-between;width:100%;\">\n                    <span style=\"font-family:DM Sans;font-size:10px;font-weight:800;color:#CBCDD8;text-transform:uppercase;letter-spacing:0.06em;\">Design skills needed</span>\n                    \n                </div>\n                <div style=\"font-family:Playfair Display;font-size:30px;font-weight:900;color:#7478FC;line-height:1;\">0</div>\n                <div style=\"width:100%;height:3px;background:#7478FC20;border-radius:999px;margin-top:2px;overflow:hidden;\">\n                    <div style=\"width:75%;height:100%;background:#7478FC;border-radius:999px;\"></div>\n                </div>\n            </div></div>\n            <p style=\"font-family:DM Sans;font-size:10.5px;color:#CBCDD8;margin:4px 0 0;line-height:1.4;opacity:0.85;\">Real-time performance telemetry metrics sampled across production worker threads.</p>\n        </div>\n            </div>\n        </div>",
