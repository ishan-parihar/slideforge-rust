    "html": "<div style=\"position:relative;width:100%;height:100%;background:var(--surface-dark);background-color:var(--surface-dark);overflow:hidden;\">\n            <div style=\"opacity: 0.04; pointer-events: none; inset: 0; position: absolute; background: var(--texture-grain); z-index: 1\"></div>\n            \n            <div class=\"slide-content\" style=\"position:relative;z-index:10;padding:72px 44px;display:flex;flex-direction:column;justify-content:center;height:100%;width:100%;box-sizing:border-box;overflow:hidden;\">\n                <div style=\"width:100%;display:flex;flex-direction:column;gap:18px;\">\n            <h2 style=\"font-family:Playfair Display;font-size:28px;font-weight:900;color:#F5ECEE;margin:0;line-height:1.08;\">Template vs Composition</h2>\n            <div style=\"display:grid;grid-template-columns:1fr auto 1fr;gap:var(--space-1);align-items:stretch;\">\n                <div style=\"border-radius:0;padding:16px;background:rgba(255,255,255,0.06);border:1px solid #3B282C;box-sizing:border-box;\">\n                    <div style=\"font-family:DM Sans;font-size:11px;font-weight:900;color:#EF4444;margin-bottom:8px;letter-spacing:0.06em;\">BEFORE</div>\n                    <p style=\"font-family:DM Sans;font-size:var(--text-sm);color:#D7CACD;line-height:1.45;margin:0;\">Template Output: Fixed 5-slide structure. Same grid on every slide. Text crammed into boxes designed for shorter content.</p>\n                </div>\n                <div style=\"display:flex;align-items:center;justify-content:center;color:#E65285;font-family:Playfair Display;font-size:22px;font-weight:900;\">\u2192</div>\n                <div style=\"border-radius:0;padding:16px;background:rgba(255,255,255,0.06);border:1px solid #3B282C;box-sizing:border-box;\">\n                    <div style=\"font-family:DM Sans;font-size:11px;font-weight:900;color:#E65285;margin-bottom:8px;letter-spacing:0.06em;\">AFTER</div>\n                    <p style=\"font-family:DM Sans;font-size:var(--text-sm);color:#D7CACD;line-height:1.45;margin:0;\">Composed Output: 8-15 slides adapted to content density. Each slide type chosen for its communication function. Typography scales to fit.</p>\n                </div>\n            </div>\n            <div style=\"margin-top:14px;border-radius:0;background:rgba(255,255,255,0.06);border:1px solid #3B282C;padding:var(--space-2) 16px;\">\n                <div style=\"font-family:Playfair Display;font-size:11px;font-weight:900;color:#E65285;letter-spacing:0.06em;margin-bottom:6px;\">Engagement Improvement</div>\n                <div style=\"font-family:DM Sans;font-size:var(--text-lg);font-weight:800;color:#F5ECEE;line-height:1.2;\">3.1x</div>\n            </div>\n        </div>\n            </div>\n        </div>",
    "background": "dark",
    "variant": "before_after_story",
    "theme": "editorial",
    "archetype": "data_analyst",
    "slide_type": "before_after_story"
  },
