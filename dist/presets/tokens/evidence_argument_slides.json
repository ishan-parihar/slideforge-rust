:12px;\">\n                <div style=\"width:34px;height:34px;border-radius:50%;background:#649B3F;color:#010200;display:flex;align-items:center;justify-content:center;font-family:Plus Jakarta Sans;font-size:13px;font-weight:900;flex-shrink:0;\">02</div>\n                <div style=\"flex:1;min-width:0;\">\n                    <div style=\"font-family:Plus Jakarta Sans;font-size:13px;font-weight:800;color:#ECF0E9;margin-bottom:2px;\">Prioritize</div>\n                    <div style=\"font-family:Plus Jakarta Sans;font-size:11px;color:#CAD0C6;line-height:1.4;\">Fix the first 3 slides first \u2014 they determine everything</div>\n                </div>\n            </div><div style=\"min-width:0;background:rgba(255,255,255,0.05);border:1px solid #273122;border-radius:0;padding:14px 14px 12px;box-sizing:border-box;display:flex;align-items:center;gap:12px;\">\n                <div style=\"width:34px;height:34px;border-radius:50%;background:#649B3F;color:#010200;display:flex;align-items:center;justify-content:center;font-family:Plus Jakarta Sans;font-size:13px;font-weight:900;flex-shrink:0;\">03</div>\n                <div style=\"flex:1;min-width:0;\">\n                    <div style=\"font-family:Plus Jakarta Sans;font-size:13px;font-weight:800;color:#ECF0E9;margin-bottom:2px;\">Rhythm</div>\n                    <div style=\"font-family:Plus Jakarta Sans;font-size:11px;color:#CAD0C6;line-height:1.4;\">Add dark-light alternation to every sequence</div>\n                </div>\n            </div><div style=\"min-width:0;background:rgba(255,255,255,0.05);border:1px solid #273122;border-radius:0;padding:14px 14px 12px;box-sizing:border-box;display:flex;align-items:center;gap:12px;\">\n                <div style=\"width:34px;height:34px;border-radius:50%;background:#649B3F;color:#010200;display:flex;align-items:center;justify-content:center;font-family:Plus Jakarta Sans;font-size:13px;font-weight:900;flex-shrink:0;\">04</div>\n                <div style=\"flex:1;min-width:0;\">\n                    <div style=\"font-family:Plus Jakarta Sans;font-size:13px;font-weight:800;color:#ECF0E9;margin-bottom:2px;\">Measure</div>\n                    <div style=\"font-family:Plus Jakarta Sans;font-size:11px;color:#CAD0C6;line-height:1.4;\">Track completion rate, not just impressions</div>\n                </div>\n            </div></div>\n            <p style=\"font-family:Plus Jakarta Sans;font-size:10.5px;color:#CAD0C6;margin:4px 0 0;line-height:1.4;opacity:0.85;\">Automated 3-step compilation pipeline converting raw JSON specifications into production-ready carousel assets.</p>\n        </div>\n            </div>\n        </div>",
