    "html": "<div style=\"position:relative;width:100%;height:100%;background:radial-gradient(at 40% 20%, #880E4F15 0px, transparent 50%), radial-gradient(at 80% 0%, #00644810 0px, transparent 50%), radial-gradient(at 0% 50%, #E1679B12 0px, transparent 50%), var(--surface-light);background-color:var(--surface-light);overflow:hidden;\">\n            <div style=\"background: var(--texture-grain); inset: 0; position: absolute; opacity: 0.04; z-index: 1; pointer-events: none\"></div>\n            \n            <div class=\"slide-content\" style=\"position:relative;z-index:10;padding:80px var(--space-6) 80px;display:flex;flex-direction:column;justify-content:center;height:100%;width:100%;box-sizing:border-box;overflow:hidden;\">\n                <div style=\"width:100%;display:flex;flex-direction:column;gap:12px;\">\n            <h2 style=\"font-family: Plus Jakarta Sans; font-size: 25px; font-weight: 600; line-height: 1.12; color: #0F090B; margin: 0 0 12px; text-align: left; letter-spacing: -0.015em; overflow-wrap: break-word\">Register in 3 Steps</h2>\n            <div style=\"display:flex;flex-direction:column;gap:10px;width:100%;\"><div style=\"min-width:0;background:rgba(255,255,255,0.92);border:1px solid #D0C3C7;border-radius:0;padding:14px 14px 12px;box-sizing:border-box;display:flex;align-items:center;gap:12px;\">\n                <div style=\"width:34px;height:34px;border-radius:50%;background:#880E4F;color:#FEF1F5;display:flex;align-items:center;justify-content:center;font-family:Plus Jakarta Sans;font-size:13px;font-weight:900;flex-shrink:0;\">01</div>\n                <div style=\"flex:1;min-width:0;\">\n                    <div style=\"font-family:Plus Jakarta Sans;font-size:13px;font-weight:800;color:#0F090B;margin-bottom:2px;\">Scan</div>\n                    <div style=\"font-family:Plus Jakarta Sans;font-size:11px;color:#493F43;line-height:1.4;\">Use the QR code to open your state&#x27;s registration page</div>\n                </div>\n            </div><div style=\"min-width:0;background:rgba(255,255,255,0.92);border:1px solid #D0C3C7;border-radius:0;padding:14px 14px 12px;box-sizing:border-box;display:flex;align-items:center;gap:12px;\">\n                <div style=\"width:34px;height:34px;border-radius:50%;background:#880E4F;color:#FEF1F5;display:flex;align-items:center;justify-content:center;font-family:Plus Jakarta Sans;font-size:13px;font-weight:900;flex-shrink:0;\">02</div>\n                <div style=\"flex:1;min-width:0;\">\n                    <div style=\"font-family:Plus Jakarta Sans;font-size:13px;font-weight:800;color:#0F090B;margin-bottom:2px;\">Fill</div>\n                    <div style=\"font-family:Plus Jakarta Sans;font-size:11px;color:#493F43;line-height:1.4;\">Name, address, ID \u2014 takes 2 minutes</div>\n                </div>\n            </div><div style=\"min-width:0;background:rgba(255,255,255,0.92);border:1px solid #D0C3C7;border-radius:0;padding:14px 14px 12px;box-sizing:border-box;display:flex;align-items:center;gap:12px;\">\n                <div style=\"width:34px;height:34px;border-radius:50%;background:#880E4F;color:#FEF1F5;display:flex;align-items:center;justify-content:center;font-family:Plus Jakarta Sans;font-size:13px;font-weight:900;flex-shrink:0;\">03</div>\n                <div style=\"flex:1;min-width:0;\">\n                    <div style=\"font-family:Plus Jakarta Sans;font-size:13px;font-weight:800;color:#0F090B;margin-bottom:2px;\">Confirm</div>\n                    <div style=\"font-family:Plus Jakarta Sans;font-size:11px;color:#493F43;line-height:1.4;\">You&#x27;ll get a confirmation email. Screenshot it.</div>\n                </div>\n            </div></div>\n            <p style=\"font-family:Plus Jakarta Sans;font-size:10.5px;color:#493F43;margin:4px 0 0;line-height:1.4;opacity:0.85;\">Automated 3-step compilation pipeline converting raw JSON specifications into production-ready carousel assets.</p>\n        </div>\n            </div>\n        </div>",
