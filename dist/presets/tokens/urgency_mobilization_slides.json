    "html": "<div style=\"position:relative;width:100%;height:100%;background:var(--surface-dark);background-color:var(--surface-dark);overflow:hidden;\">\n            <div style=\"pointer-events: none; position: absolute; inset: 0; opacity: 0.04; z-index: 1; background: var(--texture-grain)\"></div>\n            <div style=\"position:absolute;inset:0;overflow:hidden;pointer-events:none;z-index:1;\"><div style=\"height: 320px; position: absolute; border-radius: 50%; left: -80px; opacity: 0.07; background: #880E4F; top: -80px; pointer-events: none; width: 320px\"></div><div style=\"background: #006448; transform: rotate(60deg); height: 120px; opacity: 0.05; left: auto; position: absolute; border-radius: 4px; right: -40px; width: 120px; top: 60%; pointer-events: none\"></div></div>\n            <div class=\"slide-content\" style=\"position:relative;z-index:10;padding:80px var(--space-6) 80px;display:flex;flex-direction:column;justify-content:center;height:100%;width:100%;box-sizing:border-box;overflow:hidden;\">\n                <div style=\"background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);backdrop-filter:var(--glass-dark-blur);-webkit-backdrop-filter:var(--glass-dark-blur);border-radius:10px;padding:var(--space-8);\"><div style=\"display: inline-block; padding: 6px 16px; background: #D65E9115; border: 1px solid #D65E9130; border-radius: 9999px; font-family: Plus Jakarta Sans; font-size: 13px; font-weight: 600; color: #D65E91; letter-spacing: 0.05em; text-transform: uppercase; margin: 0 0 16px;\">DEADLINE FRIDAY</div><span style=\"background: linear-gradient(135deg, #FFFFFF 0%, #F4ECEF 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; font-family: Plus Jakarta Sans; font-size: 31px; font-weight: 600; line-height: 1.08; text-align: left; margin: 0; display: block; letter-spacing: -0.02em\">48 Hours Left. Your Vote Matters.</span><p style=\"font-family: Plus Jakarta Sans; font-size: 16px; font-weight: 400; line-height: 1.55; color: #D6CACE; margin: 8px 0 0; text-align: left\">District 7 registration closes Friday at midnight. If you haven&#x27;t registered, nothing else matters.</p></div>\n            </div>\n        </div>",
