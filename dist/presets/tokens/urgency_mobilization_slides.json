    "html": "<div style=\"position:relative;width:100%;height:100%;background:var(--surface-dark);background-color:var(--surface-dark);overflow:hidden;\">\n            <div style=\"inset: 0; position: absolute; pointer-events: none; background: var(--texture-grain); opacity: 0.04; z-index: 1\"></div>\n            \n            <div class=\"slide-content\" style=\"position:relative;z-index:10;padding:80px var(--space-6) 80px;display:flex;flex-direction:column;justify-content:center;height:100%;width:100%;box-sizing:border-box;overflow:hidden;\">\n                <div style=\"width:100%;display:flex;flex-direction:column;gap:12px;\">\n            <h2 style=\"font-family: Plus Jakarta Sans; font-size: 25px; font-weight: 600; line-height: 1.12; color: #F4ECEF; margin: 0 0 12px; text-align: left; letter-spacing: -0.015em; overflow-wrap: break-word\">The Numbers</h2>\n            <div style=\"display:grid;grid-template-columns:1fr 1fr;gap:12px;width:100%;\"><div style=\"background:rgba(255,255,255,0.05);border:1px solid #3A282E;border-radius:0;padding:16px 14px;box-sizing:border-box;display:flex;flex-direction:column;gap:6px;position:relative;\">\n                <div style=\"display:flex;align-items:center;justify-content:space-between;width:100%;\">\n                    <span style=\"font-family:Plus Jakarta Sans;font-size:10px;font-weight:800;color:#D6CACE;text-transform:uppercase;letter-spacing:0.06em;\">Until deadline</span>\n                    \n                </div>\n                <div style=\"font-family:Plus Jakarta Sans;font-size:30px;font-weight:900;color:#D65E91;line-height:1;\">48hrs</div>\n                <div style=\"width:100%;height:3px;background:#D65E9120;border-radius:999px;margin-top:2px;overflow:hidden;\">\n                    <div style=\"width:75%;height:100%;background:#D65E91;border-radius:999px;\"></div>\n                </div>\n            </div><div style=\"background:rgba(255,255,255,0.05);border:1px solid #3A282E;border-radius:0;padding:16px 14px;box-sizing:border-box;display:flex;flex-direction:column;gap:6px;position:relative;\">\n                <div style=\"display:flex;align-items:center;justify-content:space-between;width:100%;\">\n                    <span style=\"font-family:Plus Jakarta Sans;font-size:10px;font-weight:800;color:#D6CACE;text-transform:uppercase;letter-spacing:0.06em;\">Unregistered voters</span>\n                    \n                </div>\n                <div style=\"font-family:Plus Jakarta Sans;font-size:30px;font-weight:900;color:#D65E91;line-height:1;\">14K</div>\n                <div style=\"width:100%;height:3px;background:#D65E9120;border-radius:999px;margin-top:2px;overflow:hidden;\">\n                    <div style=\"width:75%;height:100%;background:#D65E91;border-radius:999px;\"></div>\n                </div>\n            </div><div style=\"background:rgba(255,255,255,0.05);border:1px solid #3A282E;border-radius:0;padding:16px 14px;box-sizing:border-box;display:flex;flex-direction:column;gap:6px;position:relative;\">\n                <div style=\"display:flex;align-items:center;justify-content:space-between;width:100%;\">\n                    <span style=\"font-family:Plus Jakarta Sans;font-size:10px;font-weight:800;color:#D6CACE;text-transform:uppercase;letter-spacing:0.06em;\">School funding at stake</span>\n                    \n                </div>\n                <div style=\"font-family:Plus Jakarta Sans;font-size:30px;font-weight:900;color:#D65E91;line-height:1;\">$14M</div>\n                <div style=\"width:100%;height:3px;background:#D65E9120;border-radius:999px;margin-top:2px;overflow:hidden;\">\n                    <div style=\"width:75%;height:100%;background:#D65E91;border-radius:999px;\"></div>\n                </div>\n            </div><div style=\"background:rgba(255,255,255,0.05);border:1px solid #3A282E;border-radius:0;padding:16px 14px;box-sizing:border-box;display:flex;flex-direction:column;gap:6px;position:relative;\">\n                <div style=\"display:flex;align-items:center;justify-content:space-between;width:100%;\">\n                    <span style=\"font-family:Plus Jakarta Sans;font-size:10px;font-weight:800;color:#D6CACE;text-transform:uppercase;letter-spacing:0.06em;\">Clinics closing</span>\n                    \n                </div>\n                <div style=\"font-family:Plus Jakarta Sans;font-size:30px;font-weight:900;color:#D65E91;line-height:1;\">3</div>\n                <div style=\"width:100%;height:3px;background:#D65E9120;border-radius:999px;margin-top:2px;overflow:hidden;\">\n                    <div style=\"width:75%;height:100%;background:#D65E91;border-radius:999px;\"></div>\n                </div>\n            </div></div>\n            <p style=\"font-family:Plus Jakarta Sans;font-size:10.5px;color:#D6CACE;margin:4px 0 0;line-height:1.4;opacity:0.85;\">Real-time performance telemetry metrics sampled across production worker threads.</p>\n        </div>\n            </div>\n        </div>",
