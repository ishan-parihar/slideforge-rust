    "html": "<div style=\"position:relative;width:100%;height:100%;background:var(--surface-dark);background-color:var(--surface-dark);overflow:hidden;\">\n            <div style=\"background: var(--texture-grain); position: absolute; pointer-events: none; opacity: 0.04; z-index: 1; inset: 0\"></div>\n            \n            <div class=\"slide-content--bleed\" style=\"position:relative;z-index:10;padding:0;display:flex;flex-direction:column;justify-content:stretch;height:100%;width:100%;box-sizing:border-box;overflow:hidden;\">\n                <div style=\"position:relative;width:100%;height:100%;\">\n            <div style=\"position:relative;width:100%;height:100%;border-radius: 0;overflow:hidden;background:transparent;box-sizing:border-box;\">\n                <img src=\"https://images.unsplash.com/photo-1451187580459-43490279c0fa?w=600\" alt=\"Dr. Amara Osei for City Council\" style=\"display:block;width:100%;height:100%;object-fit: cover; object-position: center;filter: contrast(1.06) brightness(1.06);\" />\n                <div style=\"position:absolute;inset:0;background:linear-gradient(to bottom, rgba(0,0,0,0.15), rgba(0,0,0,0.68));z-index:2;\"></div>\n            </div>\n            <div style=\"position:absolute;inset:0;padding:60px 28px;display:flex;flex-direction:column;justify-content:flex-end;z-index:3;\">\n                <h2 style=\"font-family:Fraunces;font-size:32px;font-weight:800;color:white;margin:0;line-height:1.15;letter-spacing:-0.02em;text-shadow:0 2px 10px rgba(0,0,0,0.7);\">Dr. Amara Osei for City Council</h2>\n                <p style=\"font-family:Outfit;font-size:13.5px;color:rgba(255,255,255,0.88);margin:10px 0 0;line-height:1.45;text-shadow:0 2px 8px rgba(0,0,0,0.6);\">15 years of public health. Now she&#x27;s running to fix what policy broke.</p>\n            </div>\n        </div>\n            </div>\n        </div>",
