    "html": "<div style=\"position:relative;width:100%;height:100%;background:radial-gradient(at 40% 20%, #C73A3E15 0px, transparent 50%), radial-gradient(at 80% 0%, #008EA310 0px, transparent 50%), radial-gradient(at 0% 50%, #FF9A9412 0px, transparent 50%), var(--surface-light);background-color:var(--surface-light);overflow:hidden;\">\n            <div style=\"background: var(--texture-grain); inset: 0; position: absolute; z-index: 1; opacity: 0.04; pointer-events: none\"></div>\n            \n            <div class=\"slide-content\" style=\"position:relative;z-index:10;padding:80px 48px 80px;display:flex;flex-direction:column;justify-content:center;height:100%;width:100%;box-sizing:border-box;overflow:hidden;\">\n                <div style=\"width:100%;box-sizing:border-box;max-width:100%;overflow:hidden;\"><h2 style=\"font-family: Fraunces; font-size: 25px; font-weight: 600; line-height: 1.12; color: #0F0A09; margin: 0 0 12px; text-align: left; letter-spacing: -0.015em; overflow-wrap: break-word\">Her Record Speaks</h2><div style=\"display:grid;grid-template-columns:repeat(2, 1fr);gap:6px;width:100%;margin-top:16px;\"><div style=\"background:#FFF1F0;border:1px solid #D1C4C325;border-radius:10px;padding:8px 10px;box-shadow:0 1px 2px rgba(0,0,0,0.05);display:flex;flex-direction:column;min-width:0;box-sizing:border-box;\">\n                    <div style=\"margin-bottom:4px;display:flex;align-items:center;justify-content:space-between;width:100%;\">\n                        <div style=\"display:flex;align-items:center;\">\ud83c\udfe5</div>\n                        <div style=\"width:18px;height:18px;background:#C73A3E;color:#FFF1F0;border-radius:50%;display:flex;align-items:center;justify-content:center;font-family:Fraunces;font-size:9px;font-weight:800;flex-shrink:0;\">1</div>\n                    </div>\n                    <h3 style=\"font-family:Outfit;font-size:11px;font-weight:600;color:#0F0A09;margin:0 0 2px;line-height:1.2;overflow-wrap:break-word;word-break:break-word;\">12 Clinics Opened</h3>\n                    <p style=\"font-family:Outfit;font-size:11px;color:#4A3F3E;margin:0;line-height:1.3;overflow-wrap:break-word;word-break:break-word;\">Built free clinics in underserved neighborhoods serving 40,000+ patients annually.</p>\n                </div><div style=\"background:#FFF1F0;border:1px solid #D1C4C325;border-radius:10px;padding:8px 10px;box-shadow:0 1px 2px rgba(0,0,0,0.05);display:flex;flex-direction:column;min-width:0;box-sizing:border-box;\">\n                    <div style=\"margin-bottom:4px;display:flex;align-items:center;justify-content:space-between;width:100%;\">\n                        <div style=\"display:flex;align-items:center;\">\ud83d\udccb</div>\n                        <div style=\"width:18px;height:18px;background:#C73A3E;color:#FFF1F0;border-radius:50%;display:flex;align-items:center;justify-content:center;font-family:Fraunces;font-size:9px;font-weight:800;flex-shrink:0;\">2</div>\n                    </div>\n                    <h3 style=\"font-family:Outfit;font-size:11px;font-weight:600;color:#0F0A09;margin:0 0 2px;line-height:1.2;overflow-wrap:break-word;word-break:break-word;\">3 Bills Authored</h3>\n                    <p style=\"font-family:Outfit;font-size:11px;color:#4A3F3E;margin:0;line-height:1.3;overflow-wrap:break-word;word-break:break-word;\">State-level legislation expanding mental health coverage for uninsured residents.</p>\n                </div><div style=\"background:#FFF1F0;border:1px solid #D1C4C325;border-radius:10px;padding:8px 10px;box-shadow:0 1px 2px rgba(0,0,0,0.05);display:flex;flex-direction:column;min-width:0;box-sizing:border-box;\">\n                    <div style=\"margin-bottom:4px;display:flex;align-items:center;justify-content:space-between;width:100%;\">\n                        <div style=\"display:flex;align-items:center;\">\ud83c\udf93</div>\n                        <div style=\"width:18px;height:18px;background:#C73A3E;color:#FFF1F0;border-radius:50%;display:flex;align-items:center;justify-content:center;font-family:Fraunces;font-size:9px;font-weight:800;flex-shrink:0;\">3</div>\n                    </div>\n                    <h3 style=\"font-family:Outfit;font-size:11px;font-weight:600;color:#0F0A09;margin:0 0 2px;line-height:1.2;overflow-wrap:break-word;word-break:break-word;\">Mentored 200+</h3>\n                    <p style=\"font-family:Outfit;font-size:11px;color:#4A3F3E;margin:0;line-height:1.3;overflow-wrap:break-word;word-break:break-word;\">Trained the next generation of community health workers through the Osei Fellowship.</p>\n                </div><div style=\"background:#FFF1F0;border:1px solid #D1C4C325;border-radius:10px;padding:8px 10px;box-shadow:0 1px 2px rgba(0,0,0,0.05);display:flex;flex-direction:column;min-width:0;box-sizing:border-box;\">\n                    <div style=\"margin-bottom:4px;display:flex;align-items:center;justify-content:space-between;width:100%;\">\n                        <div style=\"display:flex;align-items:center;\">\ud83e\udd1d</div>\n                        <div style=\"width:18px;height:18px;background:#C73A3E;color:#FFF1F0;border-radius:50%;display:flex;align-items:center;justify-content:center;font-family:Fraunces;font-size:9px;font-weight:800;flex-shrink:0;\">4</div>\n                    </div>\n                    <h3 style=\"font-family:Outfit;font-size:11px;font-weight:600;color:#0F0A09;margin:0 0 2px;line-height:1.2;overflow-wrap:break-word;word-break:break-word;\">Bipartisan Respect</h3>\n                    <p style=\"font-family:Outfit;font-size:11px;color:#4A3F3E;margin:0;line-height:1.3;overflow-wrap:break-word;word-break:break-word;\">Endorsed by both the Medical Association and the Teachers Union \u2014 rare common ground.</p>\n                </div></div></div>\n            </div>\n        </div>",
