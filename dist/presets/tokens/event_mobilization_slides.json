der-box;\">\n                <img src=\"https://images.unsplash.com/photo-1460925895917-afdab827c52f?w=600\" alt=\"Collage 4\" style=\"display:block;width:100%;height:100%;object-fit: cover; object-position: center;filter: contrast(1.02) brightness(1.02);\" />\n                \n            </div>\n            </div>\n        </div>\n            <div style=\"font-family:DM Sans;font-size:13px;color:#40424B;margin-top:8px;line-height:1.25;\">Summit highlights from previous events</div>\n        </div>\n            </div>\n        </div>",
