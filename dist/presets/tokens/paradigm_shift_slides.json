ze:12px;font-weight:600;color:#0F0A08;margin-bottom:6px;\">\n                        <span>Average quality, strong arc</span>\n                        <strong style=\"color:#0083AE;\">78</strong>\n                    </div>\n                    <div style=\"width:100%;height:12px;background:#0083AE22;border-radius:6px;overflow:hidden;\">\n                        <div style=\"width:83.0%;min-width:8px;height:100%;background:#0083AE;border-radius:6px;transition:width 0.3s;\"></div>\n                    </div>\n                </div><div style=\"margin-bottom:16px;width:100%;\">\n                    <div style=\"display:flex;justify-content:space-between;font-family:Plus Jakarta Sans;font-size:12px;font-weight:600;color:#0F0A08;margin-bottom:6px;\">\n                        <span>High quality + strong arc</span>\n                        <strong style=\"color:#BF360C;\">94</strong>\n                    </div>\n                    <div style=\"width:100%;height:12px;background:#BF360C22;border-radius:6px;overflow:hidden;\">\n                        <div style=\"width:100.0%;min-width:8px;height:100%;background:#BF360C;border-radius:6px;transition:width 0.3s;\"></div>\n                    </div>\n                </div></div>\n            \n        </div>\n            </div>\n        </div>",
