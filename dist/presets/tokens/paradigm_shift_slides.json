nt-weight:600;color:#0F0A08;margin-bottom:6px;\">\n                        <span>Design-led</span>\n                        <strong style=\"color:#0083AE;\">38</strong>\n                    </div>\n                    <div style=\"width:100%;height:12px;background:#0083AE22;border-radius:6px;overflow:hidden;\">\n                        <div style=\"width:40.9%;min-width:8px;height:100%;background:#0083AE;border-radius:6px;transition:width 0.3s;\"></div>\n                    </div>\n                </div><div style=\"margin-bottom:16px;width:100%;\">\n                    <div style=\"display:flex;justify-content:space-between;font-family:Plus Jakarta Sans;font-size:12px;font-weight:600;color:#0F0A08;margin-bottom:6px;\">\n                        <span>Structure-led</span>\n                        <strong style=\"color:#BF360C;\">71</strong>\n                    </div>\n                    <div style=\"width:100%;height:12px;background:#BF360C22;border-radius:6px;overflow:hidden;\">\n                        <div style=\"width:76.3%;min-width:8px;height:100%;background:#BF360C;border-radius:6px;transition:width 0.3s;\"></div>\n                    </div>\n                </div><div style=\"margin-bottom:16px;width:100%;\">\n                    <div style=\"display:flex;justify-content:space-between;font-family:Plus Jakarta Sans;font-size:12px;font-weight:600;color:#0F0A08;margin-bottom:6px;\">\n                        <span>Architecture-led</span>\n                        <strong style=\"color:#4A403D;\">93</strong>\n                    </div>\n                    <div style=\"width:100%;height:12px;background:#4A403D22;border-radius:6px;overflow:hidden;\">\n                        <div style=\"width:100.0%;min-width:8px;height:100%;background:#4A403D;border-radius:6px;transition:width 0.3s;\"></div>\n                    </div>\n                </div></div>\n            \n        </div>\n            </div>\n        </div>",
