    "html": "<div style=\"position:relative;width:100%;height:100%;background:radial-gradient(at 40% 20%, #C6282815 0px, transparent 50%), radial-gradient(at 80% 0%, #0088A610 0px, transparent 50%), radial-gradient(at 0% 50%, #FF978A12 0px, transparent 50%), var(--surface-light);background-color:var(--surface-light);overflow:hidden;\">\n            <div style=\"opacity: 0.04; pointer-events: none; inset: 0; position: absolute; z-index: 1; background: var(--texture-grain)\"></div>\n            \n            <div class=\"slide-content\" style=\"position:relative;z-index:10;padding:60px var(--space-6) 60px;display:flex;flex-direction:column;justify-content:center;height:100%;width:100%;box-sizing:border-box;overflow:hidden;\">\n                <div style=\"width:100%;display:flex;flex-direction:column;justify-content:center;align-items:flex-start;\">\n            <h2 style=\"font-family: Playfair Display; font-size: 25px; font-weight: 600; line-height: 1.12; color: #0F0A09; margin: 0 0 10px; text-align: left; letter-spacing: -0.015em; overflow-wrap: break-word\">Pipeline Artifacts</h2>\n            <div style=\"display:grid;grid-template-columns:1fr 1fr;grid-template-rows:1fr 1fr;gap:6px;height:210px;width:100%;\">\n                    <div style=\"position:relative;width:100%;height:100%;overflow:hidden;\">\n                <div style=\"position:relative;width:100%;height:100%;border-radius: 0;overflow:hidden;background:transparent;box-sizing:border-box;\">\n                <img src=\"https://images.unsplash.com/photo-1451187580459-43490279c0fa?w=600\" alt=\"Design tokens\" style=\"display:block;width:100%;height:100%;object-fit: cover; object-position: center;filter: contrast(1.02) brightness(1.02);\" />\n                \n            </div>\n                <div style=\"padding:5px 8px;background:rgba(0,0,0,0.62);position:absolute;top:8px;left:8px;max-width:calc(100% - 16px);z-index:3;color:white;font-family:DM Sans;font-size:10px;font-weight:800;text-align:left;border-radius:999px;letter-spacing:0.04em;text-transform:uppercase;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;\">\n                    Design tokens\n                </div>\n            </div><div style=\"position:relative;width:100%;height:100%;overflow:hidden;\">\n                <div style=\"position:relative;width:100%;height:100%;border-radius: 0;overflow:hidden;background:transparent;box-sizing:border-box;\">\n                <img src=\"https://images.unsplash.com/photo-1518770660439-4636190af475?w=600\" alt=\"Slide JSON\" style=\"display:block;width:100%;height:100%;object-fit: cover; object-position: center;filter: contrast(1.02) brightness(1.02);\" />\n                \n            </div>\n                <div style=\"padding:5px 8px;background:rgba(0,0,0,0.62);position:absolute;top:8px;left:8px;max-width:calc(100% - 16px);z-index:3;color:white;font-family:DM Sans;font-size:10px;font-weight:800;text-align:left;border-radius:999px;letter-spacing:0.04em;text-transform:uppercase;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;\">\n                    Slide JSON\n                </div>\n            </div><div style=\"position:relative;width:100%;height:100%;overflow:hidden;\">\n                <div style=\"position:relative;width:100%;height:100%;border-radius: 0;overflow:hidden;background:transparent;box-sizing:border-box;\">\n                <img src=\"https://images.unsplash.com/photo-1519389950473-47ba0277781c?w=600\" alt=\"Rendered HTML\" style=\"display:block;width:100%;height:100%;object-fit: cover; object-position: center;filter: contrast(1.02) brightness(1.02);\" />\n                \n            </div>\n                <div style=\"padding:5px 8px;background:rgba(0,0,0,0.62);position:absolute;top:8px;left:8px;max-width:calc(100% - 16px);z-index:3;color:white;font-family:DM Sans;font-size:10px;font-weight:800;text-align:left;border-radius:999px;letter-spacing:0.04em;text-transform:uppercase;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;\">\n                    Rendered HTML\n                </div>\n            </div><div style=\"position:relative;width:100%;height:100%;overflow:hidden;\">\n                <div style=\"position:relative;width:100%;height:100%;border-radius: 0;overflow:hidden;background:transparent;box-sizing:border-box;\">\n                <img src=\"https://images.unsplash.com/photo-1460925895917-afdab827c52f?w=600\" alt=\"Exported PNG\" style=\"display:block;width:100%;height:100%;object-fit: cover; object-position: center;filter: contrast(1.02) brightness(1.02);\" />\n                \n            </div>\n                <div style=\"padding:5px 8px;background:rgba(0,0,0,0.62);position:absolute;top:8px;left:8px;max-width:calc(100% - 16px);z-index:3;color:white;font-family:DM Sans;font-size:10px;font-weight:800;text-align:left;border-radius:999px;letter-spacing:0.04em;text-transform:uppercase;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;\">\n                    Exported PNG\n                </div>\n            </div>\n                </div>\n            <div style=\"font-family:DM Sans;font-size:11.5px;color:#4A3F3E;margin-top:10px;line-height:1.35;width:100%;opacity:0.9;\">From tokens to pixels \u2014 every intermediate step is inspectable</div>\n        </div>\n            </div>\n        </div>",
