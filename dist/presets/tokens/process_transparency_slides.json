    "html": "<div style=\"position:relative;width:100%;height:100%;background:var(--surface-dark);background-color:var(--surface-dark);overflow:hidden;\">\n            <div style=\"background: var(--texture-grain); position: absolute; z-index: 1; opacity: 0.04; inset: 0; pointer-events: none\"></div>\n            <div style=\"position:absolute;inset:0;overflow:hidden;pointer-events:none;z-index:1;\"><div style=\"height: 320px; width: 320px; left: -80px; top: -80px; position: absolute; background: #C62828; pointer-events: none; border-radius: 50%; opacity: 0.07\"></div><div style=\"left: auto; transform: rotate(60deg); right: -40px; background: #0088A6; opacity: 0.05; top: 60%; pointer-events: none; position: absolute; height: 120px; border-radius: 4px; width: 120px\"></div></div>\n            <div class=\"slide-content\" style=\"position:relative;z-index:10;padding:80px var(--space-6) 80px;display:flex;flex-direction:column;justify-content:center;height:100%;width:100%;box-sizing:border-box;overflow:hidden;\">\n                <div style=\"display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;width:100%;max-width:340px;margin:0 auto;box-sizing:border-box;\"><div style=\"font-family:DM Sans;font-size:10px;font-weight:800;color:#EE514A;background:#EE514A18;border:1px solid #EE514A40;padding:4px 12px;border-radius:20px;letter-spacing:0.08em;text-transform:uppercase;margin-bottom:12px;\">\u26a1 PRESENTATION ENGINE</div><span style=\"background: linear-gradient(135deg, #FFFFFF 0%, #F5ECEB 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; font-family: Playfair Display; font-size: 31px; font-weight: 600; line-height: 1.08; text-align: center; margin: 0 0 12px; display: block; letter-spacing: -0.02em\">Transparent by Design</span><p style=\"font-family:DM Sans;font-size:12px;color:#D7CAC8;line-height:1.45;margin:0 0 20px;max-width:320px;text-align:center;opacity:0.85;\">Full architecture documentation, API reference, and extension guides.</p><a href=\"https://slideforge.dev/docs\" style=\"display: inline-block; padding: 16px 40px; background: #FF978A; color: #050101; font-family: DM Sans; font-size: 16px; font-weight: 600; border-radius: 9999px; text-decoration: none; box-shadow: 0 4px 14px #91000040; letter-spacing: 0.02em; margin: 0 0 14px;\">Read the Docs</a><div style=\"font-family:DM Sans;font-size:11px;font-weight:600;color:#D7CAC8;margin-top:2px;opacity:0.85;letter-spacing:0.02em;\">\ud83d\udd17 github.com/ishan-parihar/slideforge-rust</div></div>\n            </div>\n        </div>",
