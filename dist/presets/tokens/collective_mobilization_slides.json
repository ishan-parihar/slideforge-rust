    "html": "<div style=\"position:relative;width:100%;height:100%;background:var(--surface-dark);background-color:var(--surface-dark);overflow:hidden;\">\n            <div style=\"position: absolute; inset: 0; pointer-events: none; z-index: 1; opacity: 0.04; background: var(--texture-grain)\"></div>\n            \n            <div class=\"slide-content\" style=\"position:relative;z-index:10;padding:80px var(--space-6) 80px;display:flex;flex-direction:column;justify-content:center;height:100%;width:100%;box-sizing:border-box;overflow:hidden;\">\n                <div style=\"width:100%;display:flex;flex-direction:column;gap:12px;\">\n            <h2 style=\"font-family: Plus Jakarta Sans; font-size: 25px; font-weight: 600; line-height: 1.12; color: #EBEFF5; margin: 0 0 12px; text-align: left; letter-spacing: -0.015em; overflow-wrap: break-word\">How to Join</h2>\n            <div style=\"display:flex;flex-direction:column;gap:10px;width:100%;\"><div style=\"min-width:0;background:rgba(255,255,255,0.05);border:1px solid #252E3D;border-radius:0;padding:14px 14px 12px;box-sizing:border-box;display:flex;align-items:center;gap:12px;\">\n                <div style=\"width:34px;height:34px;border-radius:50%;background:#4A84E4;color:#000205;display:flex;align-items:center;justify-content:center;font-family:Plus Jakarta Sans;font-size:13px;font-weight:900;flex-shrink:0;\">01</div>\n                <div style=\"flex:1;min-width:0;\">\n                    <div style=\"font-family:Plus Jakarta Sans;font-size:13px;font-weight:800;color:#EBEFF5;margin-bottom:2px;\">Sign</div>\n                    <div style=\"font-family:Plus Jakarta Sans;font-size:11px;color:#C8CED8;line-height:1.4;\">Add your name to the coalition petition</div>\n                </div>\n            </div><div style=\"min-width:0;background:rgba(255,255,255,0.05);border:1px solid #252E3D;border-radius:0;padding:14px 14px 12px;box-sizing:border-box;display:flex;align-items:center;gap:12px;\">\n                <div style=\"width:34px;height:34px;border-radius:50%;background:#4A84E4;color:#000205;display:flex;align-items:center;justify-content:center;font-family:Plus Jakarta Sans;font-size:13px;font-weight:900;flex-shrink:0;\">02</div>\n                <div style=\"flex:1;min-width:0;\">\n                    <div style=\"font-family:Plus Jakarta Sans;font-size:13px;font-weight:800;color:#EBEFF5;margin-bottom:2px;\">Share</div>\n                    <div style=\"font-family:Plus Jakarta Sans;font-size:11px;color:#C8CED8;line-height:1.4;\">Send this carousel to 5 people in District 7</div>\n                </div>\n            </div><div style=\"min-width:0;background:rgba(255,255,255,0.05);border:1px solid #252E3D;border-radius:0;padding:14px 14px 12px;box-sizing:border-box;display:flex;align-items:center;gap:12px;\">\n                <div style=\"width:34px;height:34px;border-radius:50%;background:#4A84E4;color:#000205;display:flex;align-items:center;justify-content:center;font-family:Plus Jakarta Sans;font-size:13px;font-weight:900;flex-shrink:0;\">03</div>\n                <div style=\"flex:1;min-width:0;\">\n                    <div style=\"font-family:Plus Jakarta Sans;font-size:13px;font-weight:800;color:#EBEFF5;margin-bottom:2px;\">Vote</div>\n                    <div style=\"font-family:Plus Jakarta Sans;font-size:11px;color:#C8CED8;line-height:1.4;\">Register and show up on election day</div>\n                </div>\n            </div><div style=\"min-width:0;background:rgba(255,255,255,0.05);border:1px solid #252E3D;border-radius:0;padding:14px 14px 12px;box-sizing:border-box;display:flex;align-items:center;gap:12px;\">\n                <div style=\"width:34px;height:34px;border-radius:50%;background:#4A84E4;color:#000205;display:flex;align-items:center;justify-content:center;font-family:Plus Jakarta Sans;font-size:13px;font-weight:900;flex-shrink:0;\">04</div>\n                <div style=\"flex:1;min-width:0;\">\n                    <div style=\"font-family:Plus Jakarta Sans;font-size:13px;font-weight:800;color:#EBEFF5;margin-bottom:2px;\">Organize</div>\n                    <div style=\"font-family:Plus Jakarta Sans;font-size:11px;color:#C8CED8;line-height:1.4;\">Become a neighborhood captain</div>\n                </div>\n            </div></div>\n            <p style=\"font-family:Plus Jakarta Sans;font-size:10.5px;color:#C8CED8;margin:4px 0 0;line-height:1.4;opacity:0.85;\">Automated 3-step compilation pipeline converting raw JSON specifications into production-ready carousel assets.</p>\n        </div>\n            </div>\n        </div>",
