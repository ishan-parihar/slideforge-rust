    "html": "<div style=\"position:relative;width:100%;height:100%;background:radial-gradient(at 40% 20%, #0D47A115 0px, transparent 50%), radial-gradient(at 80% 0%, #783D0010 0px, transparent 50%), radial-gradient(at 0% 50%, #508AEB12 0px, transparent 50%), var(--surface-light);background-color:var(--surface-light);overflow:hidden;\">\n            <div style=\"pointer-events: none; z-index: 1; position: absolute; opacity: 0.04; inset: 0; background: var(--texture-grain)\"></div>\n            \n            <div class=\"slide-content\" style=\"position:relative;z-index:10;padding:80px 48px 80px;display:flex;flex-direction:column;justify-content:center;height:100%;width:100%;box-sizing:border-box;overflow:hidden;\">\n                <div style=\"width:100%;box-sizing:border-box;max-width:100%;overflow:hidden;\"><h2 style=\"font-family: Plus Jakarta Sans; font-size: 25px; font-weight: 600; line-height: 1.12; color: #090B0F; margin: 0 0 12px; text-align: left; letter-spacing: -0.015em; overflow-wrap: break-word\">Our Demands</h2><div style=\"display:grid;grid-template-columns:repeat(2, 1fr);gap:6px;width:100%;flex:1;min-height:0;margin-top:8px;\"><div style=\"flex:1;min-width:0;min-height:0;background:#EFF6FF;border:1px solid #C2C8D125;border-radius:10px;padding:6px 8px;box-shadow:0 1px 2px rgba(0,0,0,0.05);display:flex;flex-direction:column;box-sizing:border-box;\">\n                <div style=\"margin-bottom:4px;display:flex;align-items:center;flex-shrink:0;\">\ud83c\udfe0</div>\n                <h3 style=\"font-family:Plus Jakarta Sans;font-size:11px;font-weight:600;color:#090B0F;margin:0 0 3px;line-height:1.25;overflow-wrap:break-word;word-break:break-word;\">Housing</h3>\n                <p style=\"font-family:Plus Jakarta Sans;font-size:9px;color:#3E434B;margin:0;line-height:1.35;overflow-wrap:break-word;word-break:break-word;flex:1;min-height:0;\">30% affordable units in all new developments. No exceptions.</p>\n            </div><div style=\"flex:1;min-width:0;min-height:0;background:#EFF6FF;border:1px solid #C2C8D125;border-radius:10px;padding:6px 8px;box-shadow:0 1px 2px rgba(0,0,0,0.05);display:flex;flex-direction:column;box-sizing:border-box;\">\n                <div style=\"margin-bottom:4px;display:flex;align-items:center;flex-shrink:0;\">\ud83c\udfe5</div>\n                <h3 style=\"font-family:Plus Jakarta Sans;font-size:11px;font-weight:600;color:#090B0F;margin:0 0 3px;line-height:1.25;overflow-wrap:break-word;word-break:break-word;\">Healthcare</h3>\n                <p style=\"font-family:Plus Jakarta Sans;font-size:9px;color:#3E434B;margin:0;line-height:1.35;overflow-wrap:break-word;word-break:break-word;flex:1;min-height:0;\">Renewed funding for all 3 community clinics. Permanent, not temporary.</p>\n            </div><div style=\"flex:1;min-width:0;min-height:0;background:#EFF6FF;border:1px solid #C2C8D125;border-radius:10px;padding:6px 8px;box-shadow:0 1px 2px rgba(0,0,0,0.05);display:flex;flex-direction:column;box-sizing:border-box;\">\n                <div style=\"margin-bottom:4px;display:flex;align-items:center;flex-shrink:0;\">\ud83c\udf33</div>\n                <h3 style=\"font-family:Plus Jakarta Sans;font-size:11px;font-weight:600;color:#090B0F;margin:0 0 3px;line-height:1.25;overflow-wrap:break-word;word-break:break-word;\">Green Space</h3>\n                <p style=\"font-family:Plus Jakarta Sans;font-size:9px;color:#3E434B;margin:0;line-height:1.35;overflow-wrap:break-word;word-break:break-word;flex:1;min-height:0;\">Park renovation fund. Every neighborhood deserves a park.</p>\n            </div><div style=\"flex:1;min-width:0;min-height:0;background:#EFF6FF;border:1px solid #C2C8D125;border-radius:10px;padding:6px 8px;box-shadow:0 1px 2px rgba(0,0,0,0.05);display:flex;flex-direction:column;box-sizing:border-box;\">\n                <div style=\"margin-bottom:4px;display:flex;align-items:center;flex-shrink:0;\">\ud83d\udcda</div>\n                <h3 style=\"font-family:Plus Jakarta Sans;font-size:11px;font-weight:600;color:#090B0F;margin:0 0 3px;line-height:1.25;overflow-wrap:break-word;word-break:break-word;\">Education</h3>\n                <p style=\"font-family:Plus Jakarta Sans;font-size:9px;color:#3E434B;margin:0;line-height:1.35;overflow-wrap:break-word;word-break:break-word;flex:1;min-height:0;\">Equalized school funding. No district should get less per student.</p>\n            </div></div></div>\n            </div>\n        </div>",
