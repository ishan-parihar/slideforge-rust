    "html": "<div style=\"position:relative;width:100%;height:100%;background:radial-gradient(at 40% 20%, #2E7D3215 0px, transparent 50%), radial-gradient(at 80% 0%, #8F4B9510 0px, transparent 50%), radial-gradient(at 0% 50%, #77C57712 0px, transparent 50%), var(--surface-light);background-color:var(--surface-light);overflow:hidden;\">\n            <div style=\"inset: 0; pointer-events: none; background: var(--texture-grain); position: absolute; z-index: 1; opacity: 0.04\"></div>\n            \n            <div class=\"slide-content\" style=\"position:relative;z-index:10;padding:80px 48px 80px;display:flex;flex-direction:column;justify-content:center;height:100%;width:100%;box-sizing:border-box;overflow:hidden;\">\n                <div style=\"width:100%;box-sizing:border-box;max-width:100%;overflow:hidden;\"><h2 style=\"font-family: Plus Jakarta Sans; font-size: 25px; font-weight: 600; line-height: 1.12; color: #090C09; margin: 0 0 12px; text-align: left; letter-spacing: -0.015em; overflow-wrap: break-word\">Core Beliefs</h2><div style=\"display:grid;grid-template-columns:repeat(2, 1fr);gap:6px;width:100%;margin-top:16px;\"><div style=\"background:#EFF8EF;border:1px solid #C2CAC125;border-radius:10px;padding:8px 10px;box-shadow:0 1px 2px rgba(0,0,0,0.05);display:flex;flex-direction:column;min-width:0;box-sizing:border-box;\">\n                    <div style=\"margin-bottom:4px;display:flex;align-items:center;justify-content:space-between;width:100%;\">\n                        <div style=\"display:flex;align-items:center;\">\ud83d\udd27</div>\n                        <div style=\"width:18px;height:18px;background:#2E7D32;color:#EFF8EF;border-radius:50%;display:flex;align-items:center;justify-content:center;font-family:Plus Jakarta Sans;font-size:9px;font-weight:800;flex-shrink:0;\">1</div>\n                    </div>\n                    <h3 style=\"font-family:Plus Jakarta Sans;font-size:11px;font-weight:600;color:#090C09;margin:0 0 2px;line-height:1.2;overflow-wrap:break-word;word-break:break-word;\">Tools, Not Templates</h3>\n                    <p style=\"font-family:Plus Jakarta Sans;font-size:11px;color:#3E453D;margin:0;line-height:1.3;overflow-wrap:break-word;word-break:break-word;\">SlideForge doesn&#x27;t pick your content. It gives you a composition engine and gets out of the way.</p>\n                </div><div style=\"background:#EFF8EF;border:1px solid #C2CAC125;border-radius:10px;padding:8px 10px;box-shadow:0 1px 2px rgba(0,0,0,0.05);display:flex;flex-direction:column;min-width:0;box-sizing:border-box;\">\n                    <div style=\"margin-bottom:4px;display:flex;align-items:center;justify-content:space-between;width:100%;\">\n                        <div style=\"display:flex;align-items:center;\">\ud83d\udcd0</div>\n                        <div style=\"width:18px;height:18px;background:#2E7D32;color:#EFF8EF;border-radius:50%;display:flex;align-items:center;justify-content:center;font-family:Plus Jakarta Sans;font-size:9px;font-weight:800;flex-shrink:0;\">2</div>\n                    </div>\n                    <h3 style=\"font-family:Plus Jakarta Sans;font-size:11px;font-weight:600;color:#090C09;margin:0 0 2px;line-height:1.2;overflow-wrap:break-word;word-break:break-word;\">Composition Over Decoration</h3>\n                    <p style=\"font-family:Plus Jakarta Sans;font-size:11px;color:#3E453D;margin:0;line-height:1.3;overflow-wrap:break-word;word-break:break-word;\">Every slide type exists to solve a communication problem, not to look pretty.</p>\n                </div><div style=\"background:#EFF8EF;border:1px solid #C2CAC125;border-radius:10px;padding:8px 10px;box-shadow:0 1px 2px rgba(0,0,0,0.05);display:flex;flex-direction:column;min-width:0;box-sizing:border-box;\">\n                    <div style=\"margin-bottom:4px;display:flex;align-items:center;justify-content:space-between;width:100%;\">\n                        <div style=\"display:flex;align-items:center;\"><svg viewBox=\"0 0 24 24\" width=\"18\" height=\"18\" fill=\"none\" stroke=\"#2E7D32\" stroke-linecap=\"round\" stroke-linejoin=\"round\" style=\"display:inline-block;vertical-align:middle;color:#2E7D32;\"><path d=\"M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z\"/><path d=\"m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z\"/><path d=\"M9 12H4s.55-3.03 2-4.5c1.39-1.4 4.5-2 4.5-2z\"/><path d=\"M12 15v5s3.03-.55 4.5-2c1.4-1.39 2-4.5 2-4.5z\" stroke-width=\"2\"/></svg></div>\n                        <div style=\"width:18px;height:18px;background:#2E7D32;color:#EFF8EF;border-radius:50%;display:flex;align-items:center;justify-content:center;font-family:Plus Jakarta Sans;font-size:9px;font-weight:800;flex-shrink:0;\">3</div>\n                    </div>\n                    <h3 style=\"font-family:Plus Jakarta Sans;font-size:11px;font-weight:600;color:#090C09;margin:0 0 2px;line-height:1.2;overflow-wrap:break-word;word-break:break-word;\">Ship in Seconds</h3>\n                    <p style=\"font-family:Plus Jakarta Sans;font-size:11px;color:#3E453D;margin:0;line-height:1.3;overflow-wrap:break-word;word-break:break-word;\">If generation takes more than 60 seconds, something is wrong. Speed is a feature.</p>\n                </div><div style=\"background:#EFF8EF;border:1px solid #C2CAC125;border-radius:10px;padding:8px 10px;box-shadow:0 1px 2px rgba(0,0,0,0.05);display:flex;flex-direction:column;min-width:0;box-sizing:border-box;\">\n                    <div style=\"margin-bottom:4px;display:flex;align-items:center;justify-content:space-between;width:100%;\">\n                        <div style=\"display:flex;align-items:center;\">\ud83d\udd13</div>\n                        <div style=\"width:18px;height:18px;background:#2E7D32;color:#EFF8EF;border-radius:50%;display:flex;align-items:center;justify-content:center;font-family:Plus Jakarta Sans;font-size:9px;font-weight:800;flex-shrink:0;\">4</div>\n                    </div>\n                    <h3 style=\"font-family:Plus Jakarta Sans;font-size:11px;font-weight:600;color:#090C09;margin:0 0 2px;line-height:1.2;overflow-wrap:break-word;word-break:break-word;\">Open Pipeline</h3>\n                    <p style=\"font-family:Plus Jakarta Sans;font-size:11px;color:#3E453D;margin:0;line-height:1.3;overflow-wrap:break-word;word-break:break-word;\">CLI for humans, MCP for agents. Same engine, same output. No walled gardens.</p>\n                </div></div></div>\n            </div>\n        </div>",
