    "html": "<div style=\"position:relative;width:100%;height:100%;background:var(--surface-dark);background-color:var(--surface-dark);overflow:hidden;\">\n            <div style=\"pointer-events: none; position: absolute; opacity: 0.04; inset: 0; z-index: 1; background: var(--texture-grain)\"></div>\n            \n            <div class=\"slide-content\" style=\"position:relative;z-index:10;padding:80px var(--space-6) 80px;display:flex;flex-direction:column;justify-content:center;height:100%;width:100%;box-sizing:border-box;overflow:hidden;\">\n                <div style=\"width:100%;display:flex;flex-direction:column;gap:12px;\">\n            <h2 style=\"font-family: Plus Jakarta Sans; font-size: 25px; font-weight: 600; line-height: 1.12; color: #F5ECEA; margin: 0 0 12px; text-align: left; letter-spacing: -0.015em; overflow-wrap: break-word\">The Accountability Chain</h2>\n            <div style=\"display:flex;flex-direction:column;gap:10px;width:100%;\"><div style=\"min-width:0;background:rgba(255,255,255,0.05);border:1px solid #3B2923;border-radius:0;padding:14px 14px 12px;box-sizing:border-box;display:flex;align-items:center;gap:12px;\">\n                <div style=\"width:34px;height:34px;border-radius:50%;background:#EA542A;color:#050100;display:flex;align-items:center;justify-content:center;font-family:Plus Jakarta Sans;font-size:13px;font-weight:900;flex-shrink:0;\">01</div>\n                <div style=\"flex:1;min-width:0;\">\n                    <div style=\"font-family:Plus Jakarta Sans;font-size:13px;font-weight:800;color:#F5ECEA;margin-bottom:2px;\">Investigate</div>\n                    <div style=\"font-family:Plus Jakarta Sans;font-size:11px;color:#D7CBC7;line-height:1.4;\">Public records reveal where ratepayer money actually goes</div>\n                </div>\n            </div><div style=\"min-width:0;background:rgba(255,255,255,0.05);border:1px solid #3B2923;border-radius:0;padding:14px 14px 12px;box-sizing:border-box;display:flex;align-items:center;gap:12px;\">\n                <div style=\"width:34px;height:34px;border-radius:50%;background:#EA542A;color:#050100;display:flex;align-items:center;justify-content:center;font-family:Plus Jakarta Sans;font-size:13px;font-weight:900;flex-shrink:0;\">02</div>\n                <div style=\"flex:1;min-width:0;\">\n                    <div style=\"font-family:Plus Jakarta Sans;font-size:13px;font-weight:800;color:#F5ECEA;margin-bottom:2px;\">Expose</div>\n                    <div style=\"font-family:Plus Jakarta Sans;font-size:11px;color:#D7CBC7;line-height:1.4;\">Share findings with affected communities</div>\n                </div>\n            </div><div style=\"min-width:0;background:rgba(255,255,255,0.05);border:1px solid #3B2923;border-radius:0;padding:14px 14px 12px;box-sizing:border-box;display:flex;align-items:center;gap:12px;\">\n                <div style=\"width:34px;height:34px;border-radius:50%;background:#EA542A;color:#050100;display:flex;align-items:center;justify-content:center;font-family:Plus Jakarta Sans;font-size:13px;font-weight:900;flex-shrink:0;\">03</div>\n                <div style=\"flex:1;min-width:0;\">\n                    <div style=\"font-family:Plus Jakarta Sans;font-size:13px;font-weight:800;color:#F5ECEA;margin-bottom:2px;\">Legislate</div>\n                    <div style=\"font-family:Plus Jakarta Sans;font-size:11px;color:#D7CBC7;line-height:1.4;\">Support transparency laws that prevent misuse</div>\n                </div>\n            </div><div style=\"min-width:0;background:rgba(255,255,255,0.05);border:1px solid #3B2923;border-radius:0;padding:14px 14px 12px;box-sizing:border-box;display:flex;align-items:center;gap:12px;\">\n                <div style=\"width:34px;height:34px;border-radius:50%;background:#EA542A;color:#050100;display:flex;align-items:center;justify-content:center;font-family:Plus Jakarta Sans;font-size:13px;font-weight:900;flex-shrink:0;\">04</div>\n                <div style=\"flex:1;min-width:0;\">\n       