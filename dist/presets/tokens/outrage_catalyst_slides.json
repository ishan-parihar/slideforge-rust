ont-weight:600;color:#0F0A08;margin-bottom:6px;\">\n                        <span>Profit margin</span>\n                        <strong style=\"color:#008BBC;\">18</strong>\n                    </div>\n                    <div style=\"width:100%;height:12px;background:#008BBC22;border-radius:6px;overflow:hidden;\">\n                        <div style=\"width:29.0%;min-width:8px;height:100%;background:#008BBC;border-radius:6px;transition:width 0.3s;\"></div>\n                    </div>\n                </div><div style=\"margin-bottom:16px;width:100%;\">\n                    <div style=\"display:flex;justify-content:space-between;font-family:Plus Jakarta Sans;font-size:12px;font-weight:600;color:#0F0A08;margin-bottom:6px;\">\n                        <span>Admin/exec</span>\n                        <strong style=\"color:#CD3800;\">12</strong>\n                    </div>\n                    <div style=\"width:100%;height:12px;background:#CD380022;border-radius:6px;overflow:hidden;\">\n                        <div style=\"width:19.4%;min-width:8px;height:100%;background:#CD3800;border-radius:6px;transition:width 0.3s;\"></div>\n                    </div>\n                </div><div style=\"margin-bottom:16px;width:100%;\">\n                    <div style=\"display:flex;justify-content:space-between;font-family:Plus Jakarta Sans;font-size:12px;font-weight:600;color:#0F0A08;margin-bottom:6px;\">\n                        <span>Political spending</span>\n                        <strong style=\"color:#4A403D;\">8</strong>\n                    </div>\n                    <div style=\"width:100%;height:12px;background:#4A403D22;border-radius:6px;overflow:hidden;\">\n                        <div style=\"width:12.9%;min-width:8px;height:100%;background:#4A403D;border-radius:6px;transition:width 0.3s;\"></div>\n                    </div>\n                </div></div>\n            \n        </div>\n            </div>\n        </div>",
