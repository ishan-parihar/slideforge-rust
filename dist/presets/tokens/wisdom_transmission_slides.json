    "html": "<div style=\"position:relative;width:100%;height:100%;background:var(--surface-dark);background-color:var(--surface-dark);overflow:hidden;\">\n            <div style=\"inset: 0; background: var(--texture-grain); z-index: 1; opacity: 0.04; pointer-events: none; position: absolute\"></div>\n            \n            <div class=\"slide-content\" style=\"position:relative;z-index:10;padding:80px var(--space-6) 80px;display:flex;flex-direction:column;justify-content:center;height:100%;width:100%;box-sizing:border-box;overflow:hidden;\">\n                <div style=\"position:relative;width:100%;height:100%;display:flex;align-items:center;justify-content:center;box-sizing:border-box;\">\n            <div style=\"position:absolute;left:-80px;top:-80px;width:260px;height:260px;border-radius:50%;background:#5E5FE0;opacity:0.06;filter:blur(50px);-webkit-filter:blur(50px);pointer-events:none;z-index:1;\"></div>\n            <div style=\"position:absolute;right:var(--space-5);bottom:var(--space-4);font-size:240px;opacity:0.04;pointer-events:none;z-index:1;user-select:none;transform:rotate(12deg);line-height:1;font-family:system-ui;\">\ud83d\udca1</div>\n            <div style=\"border: 1px solid #2A2C3D40; backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); background: #010105CC; border-radius: 16px; border-left: 6px solid #5E5FE0;padding:36px 32px;box-shadow: 0 8px 32px -4px #5E5FE01f, 0 4px 6px -1px rgba(0,0,0,0.08), 0 2px 4px -2px rgba(0,0,0,0.05);width:100%;box-sizing:border-box;position:relative;z-index:2;\">\n                <div style=\"display:flex;align-items:center;gap:18px;margin-bottom:18px;\">\n                    <div style=\"width:44px;height:44px;min-width:44px;border-radius:50%;background:#5E5FE01a;color:#5E5FE0;display:flex;align-items:center;justify-content:center;font-size:20px;box-shadow:inset 0 1px 3px rgba(255,255,255,0.1);\">\ud83d\udca1</div>\n                    <div>\n                        <span style=\"font-size:9.5px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:#5E5FE0;margin-bottom:4px;display:block;\">info</span>\n                        <h2 style=\"font-family:Playfair Display;font-size:20px;font-weight:800;color:#EDEEF5;margin:0;line-height:1.2;\">The Transmission Is Complete When</h2>\n                    </div>\n                </div>\n                <p style=\"font-family:DM Sans;font-size:16px;line-height:1.65;color:#CBCDD8;margin:0;overflow-wrap:break-word;word-break:break-word;\">The audience doesn&#x27;t remember your words \u2014 they remember their own realization. That&#x27;s when teaching becomes transformation.</p>\n            </div>\n        </div>\n            </div>\n        </div>",
