ont-weight:800;flex-shrink:0;\">2</div>\n                    <div style=\"font-family:Plus Jakarta Sans;font-size:var(--text-sm);font-weight:700;color:#070D0B;line-height:1.45;\">Map the emotional arc of a competitor&#x27;s carousel</div>\n                </div><div style=\"display:flex;gap:var(--space-1);align-items:flex-start;background:rgba(255,255,255,0.92);border:1px solid #BDCBC8;border-radius:0;padding:var(--space-1) 14px;\">\n                    <div style=\"width:24px;height:24px;border-radius:50%;background:#00695C;color:white;display:flex;align-items:center;justify-content:center;font-family:Plus Jakarta Sans;font-size:12px;font-weight:800;flex-shrink:0;\">3</div>\n                    <div style=\"font-family:Plus Jakarta Sans;font-size:var(--text-sm);font-weight:700;color:#070D0B;line-height:1.45;\">Generate one carousel using a preset</div>\n                </div><div style=\"display:flex;gap:var(--space-1);align-items:flex-start;background:rgba(255,255,255,0.92);border:1px solid #BDCBC8;border-radius:0;padding:var(--space-1) 14px;\">\n                    <div style=\"width:24px;height:24px;border-radius:50%;background:#00695C;color:white;display:flex;align-items:center;justify-content:center;font-family:Plus Jakarta Sans;font-size:12px;font-weight:800;flex-shrink:0;\">4</div>\n                    <div style=\"font-family:Plus Jakarta Sans;font-size:var(--text-sm);font-weight:700;color:#070D0B;line-height:1.45;\">Measure completion rate</div>\n                </div></div></div>\n            </div>\n        </div>",
