    "html": "<div style=\"position:relative;width:100%;height:100%;background:radial-gradient(at 40% 20%, #00695C15 0px, transparent 50%), radial-gradient(at 80% 0%, #80445810 0px, transparent 50%), radial-gradient(at 0% 50%, #5CAFA012 0px, transparent 50%), var(--surface-light);background-color:var(--surface-light);overflow:hidden;\">\n            <div style=\"pointer-events: none; z-index: 1; inset: 0; background: var(--texture-grain); position: absolute; opacity: 0.04\"></div>\n            \n            <div class=\"slide-content\" style=\"position:relative;z-index:10;padding:72px 44px;display:flex;flex-direction:column;justify-content:center;height:100%;width:100%;box-sizing:border-box;overflow:hidden;\">\n                <div style=\"width:100%;background:rgba(255,255,255,0.92);border:1px solid #BDCBC8;border-radius:0;padding:22px 20px;box-sizing:border-box;display:flex;flex-direction:column;gap:4px;\">\n            <span style=\"font-family:Plus Jakarta Sans;font-size:9.5px;font-weight:900;letter-spacing:0.12em;text-transform:uppercase;color:#00695C;background:#00695C18;padding:2px 8px;border-radius:4px;display:inline-block;margin-bottom:8px;\">CORE DEFINITION</span>\n            <h2 style=\"font-family:Plus Jakarta Sans;font-size:28px;font-weight:900;color:#070D0B;margin:0 0 4px;line-height:1.1;\">Emotional Architecture</h2>\n            <div style=\"font-family:Plus Jakarta Sans;font-size:11px;font-style:italic;color:#3A4543;margin-bottom:12px;opacity:0.8;\">/\u026a\u02ccmo\u028a\u0283\u0259nl \u02c8\u0251\u02d0rk\u026at\u025bkt\u0283\u0259r/</div>\n            <div style=\"border-left:3px solid #00695C;padding-left:14px;margin:12px 0 14px;\">\n            <p style=\"font-family:Plus Jakarta Sans;font-size:13px;font-weight:500;color:#070D0B;margin:0;line-height:1.5;\">The deliberate design of communication sequences that guide audiences through specific emotional progressions toward a predetermined action.</p>\n        </div>\n            <p style=\"font-family:Plus Jakarta Sans;font-size:10.5px;color:#3A4543;margin:0;line-height:1.4;opacity:0.85;\">Every effective campaign uses emotional architecture \u2014 most just don&#x27;t know it. Learning the framework turns intuition into a repeatable skill.</p>\n        </div>\n            </div>\n        </div>",
