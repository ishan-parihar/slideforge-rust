    "html": "<div style=\"position:relative;width:100%;height:100%;background:var(--surface-dark);background-color:var(--surface-dark);overflow:hidden;\">\n            <div style=\"pointer-events: none; inset: 0; background: var(--texture-grain); z-index: 1; position: absolute; opacity: 0.04\"></div>\n            <div style=\"position:absolute;inset:0;overflow:hidden;pointer-events:none;z-index:1;\"><div style=\"border-radius: 50%; position: absolute; height: 320px; left: -80px; background: #007A86; pointer-events: none; width: 320px; opacity: 0.07; top: -80px\"></div><div style=\"border-radius: 4px; height: 120px; top: 60%; right: -40px; transform: rotate(60deg); position: absolute; width: 120px; background: #99564F; opacity: 0.05; left: auto; pointer-events: none\"></div></div>\n            <div class=\"slide-content\" style=\"position:relative;z-index:10;padding:80px 52px;display:flex;flex-direction:column;justify-content:center;height:100%;width:100%;box-sizing:border-box;overflow:hidden;\">\n                <div style=\"width:100%;height:100%;display:flex;flex-direction:column;justify-content:center;\">\n            <div style=\"font-family:Plus Jakarta Sans;font-size:12px;font-weight:800;color:#2E929E;letter-spacing:0.08em;text-transform:uppercase;margin-bottom:18px;\">CASE STUDY</div>\n            <h1 style=\"font-family:Plus Jakarta Sans;font-size:31px;font-weight:900;color:#E7F0F2;line-height:1.02;margin:0;max-width:320px;\">How Relay.so Cut Content Production by 90%</h1>\n            <div style=\"width:76px;height:4px;background:#2E929E;border-radius:0;margin:var(--space-3) 0;\"></div>\n            <p style=\"font-family:Plus Jakarta Sans;font-size:15px;color:#C3D1D3;line-height:1.45;margin:0;max-width:300px;\">From 12-hour design sprints to 60-second generation</p>\n        </div>\n            </div>\n        </div>",
