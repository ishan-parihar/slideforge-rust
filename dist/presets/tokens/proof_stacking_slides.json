    "html": "<div style=\"position:relative;width:100%;height:100%;background:var(--surface-dark);background-color:var(--surface-dark);overflow:hidden;\">\n            <div style=\"pointer-events: none; background: var(--texture-grain); position: absolute; z-index: 1; opacity: 0.04; inset: 0\"></div>\n            \n            <div class=\"slide-content\" style=\"position:relative;z-index:10;padding:72px 44px;display:flex;flex-direction:column;justify-content:center;height:100%;width:100%;box-sizing:border-box;overflow:hidden;\">\n                <div style=\"width:100%;display:flex;flex-direction:column;gap:18px;\">\n            <h2 style=\"font-family:Plus Jakarta Sans;font-size:28px;font-weight:900;color:#E7F0F2;margin:0;line-height:1.08;\">Relay.so Marketing Team</h2>\n            <div style=\"display:grid;grid-template-columns:1fr 1fr;gap:14px;\">\n                <div style=\"border-radius:0;padding:18px;background:rgba(255,255,255,0.06);border:1px solid #1B3235;\"><div style=\"font-family:Plus Jakarta Sans;font-size:11px;font-weight:800;color:#EF4444;margin-bottom:8px;\">PROBLEM</div><p style=\"font-family:Plus Jakarta Sans;font-size:var(--text-sm);color:#C3D1D3;line-height:1.45;margin:0;\">Scale Instagram content from 2 campaigns/month to daily posting without hiring designers.</p></div>\n                <div style=\"border-radius:0;padding:18px;background:rgba(255,255,255,0.06);border:1px solid #1B3235;\"><div style=\"font-family:Plus Jakarta Sans;font-size:11px;font-weight:800;color:#2E929E;margin-bottom:8px;\">SOLUTION</div><p style=\"font-family:Plus Jakarta Sans;font-size:var(--text-sm);color:#C3D1D3;line-height:1.45;margin:0;\">Nexus generates campaign carousels from product briefs. Team reviews, tweaks copy, and publishes.</p></div>\n            </div>\n            <div style=\"background:rgba(255,255,255,0.06);border:1px solid #1B3235;border-radius:0;padding:12px 16px;width:100%;box-sizing:border-box;\">\n                <div style=\"font-family:Plus Jakarta Sans;font-size:10px;font-weight:800;color:#2E929E;letter-spacing:0.08em;text-transform:uppercase;margin-bottom:4px;\">KEY IMPACT & PROOF</div>\n                <div style=\"font-family:Plus Jakarta Sans;font-size:11px;color:#C3D1D3;line-height:1.45;\">Content Output &nbsp;\u2022&nbsp; Annual Savings</div>\n            </div>\n        </div>\n            </div>\n        </div>",
