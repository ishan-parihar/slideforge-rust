    "html": "<div style=\"position:relative;width:100%;height:100%;background:var(--surface-dark);background-color:var(--surface-dark);overflow:hidden;\">\n            <div style=\"position: absolute; inset: 0; background: var(--texture-grain); pointer-events: none; opacity: 0.04; z-index: 1\"></div>\n            \n            <div class=\"slide-content\" style=\"position:relative;z-index:10;padding:80px var(--space-6) 80px;display:flex;flex-direction:column;justify-content:center;height:100%;width:100%;box-sizing:border-box;overflow:hidden;\">\n                <div style=\"width:100%;display:flex;flex-direction:column;align-items:center;\"><h2 style=\"font-family: Plus Jakarta Sans; font-size: 20px; font-weight: 600; line-height: 1.18; color: var(--text-primary, #0B0A0F); margin: 0 0 10px; text-align: left; letter-spacing: -0.01em; overflow-wrap: break-word\">Technique Mastery Profile</h2><div style=\"width:100%;max-width:320px;height:210px;margin:4px auto 0;\"><svg width=\"100%\" height=\"210px\" viewBox=\"0 0 320 210\" xmlns=\"http://www.w3.org/2000/svg\">\n            <polygon points=\"160.0,84.0 175.2,95.1 169.4,112.9 150.6,112.9 144.8,95.1\" fill=\"none\" stroke=\"#312F1D33\" stroke-width=\"1\" /><polygon points=\"160.0,68.0 190.4,90.1 178.8,125.9 141.2,125.9 129.6,90.1\" fill=\"none\" stroke=\"#312F1D33\" stroke-width=\"1\" /><polygon points=\"160.0,52.0 205.7,85.2 188.2,138.8 131.8,138.8 114.3,85.2\" fill=\"none\" stroke=\"#312F1D33\" stroke-width=\"1\" /><polygon points=\"160.0,36.0 220.9,80.2 197.6,151.8 122.4,151.8 99.1,80.2\" fill=\"none\" stroke=\"#312F1D33\" stroke-width=\"1\" /><polygon points=\"160.0,20.0 236.1,75.3 207.0,164.7 113.0,164.7 83.9,75.3\" fill=\"none\" stroke=\"#312F1D33\" stroke-width=\"1\" />\n            <line x1=\"160\" y1=\"100\" x2=\"160.0\" y2=\"20.0\" stroke=\"#312F1D33\" stroke-width=\"1\" /><text x=\"160.0\" y=\"13.0\" font-size=\"10px\" font-weight=\"700\" fill=\"#EFEFE7\" text-anchor=\"middle\">Pattern Interrupt (85)</text><line x1=\"160\" y1=\"100\" x2=\"236.1\" y2=\"75.3\" stroke=\"#312F1D33\" stroke-width=\"1\" /><text x=\"251.4\" y=\"75.2\" font-size=\"10px\" font-weight=\"700\" fill=\"#EFEFE7\" text-anchor=\"start\">Anchoring (92)</text><line x1=\"160\" y1=\"100\" x2=\"207.0\" y2=\"164.7\" stroke=\"#312F1D33\" stroke-width=\"1\" /><text x=\"217.3\" y=\"175.8\" font-size=\"10px\" font-weight=\"700\" fill=\"#EFEFE7\" text-anchor=\"start\">Commitment (78)</text><line x1=\"160\" y1=\"100\" x2=\"113.0\" y2=\"164.7\" stroke=\"#312F1D33\" stroke-width=\"1\" /><text x=\"102.7\" y=\"175.8\" font-size=\"10px\" font-weight=\"700\" fill=\"#EFEFE7\" text-anchor=\"end\">Identity (88)</text><line x1=\"160\" y1=\"100\" x2=\"83.9\" y2=\"75.3\" stroke=\"#312F1D33\" stroke-width=\"1\" /><text x=\"68.6\" y=\"75.2\" font-size=\"10px\" font-weight=\"700\" fill=\"#EFEFE7\" text-anchor=\"end\">Transport (95)</text>\n            <polygon points=\"160.0,28.4 233.7,76.1 198.6,153.1 116.4,160.0 83.9,75.3\" fill=\"#9A8F36\" fill-opacity=\"0.25\" stroke=\"#9A8F36\" stroke-width=\"2\" />\n            <circle cx=\"160.0\" cy=\"28.4\" r=\"4\" fill=\"#9A8F36\" stroke=\"#ffffff\" stroke-width=\"1.5\" /><circle cx=\"233.7\" cy=\"76.1\" r=\"4\" fill=\"#9A8F36\" stroke=\"#ffffff\" stroke-width=\"1.5\" /><circle cx=\"198.6\" cy=\"153.1\" r=\"4\" fill=\"#9A8F36\" stroke=\"#ffffff\" stroke-width=\"1.5\" /><circle cx=\"116.4\" cy=\"160.0\" r=\"4\" fill=\"#9A8F36\" stroke=\"#ffffff\" stroke-width=\"1.5\" /><circle cx=\"83.9\" cy=\"75.3\" r=\"4\" fill=\"#9A8F36\" stroke=\"#ffffff\" stroke-width=\"1.5\" />\n        </svg></div></div>\n            </div>\n        </div>",
