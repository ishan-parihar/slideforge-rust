    "html": "<div style=\"position:relative;width:100%;height:100%;background:radial-gradient(at 40% 20%, #7C710C15 0px, transparent 50%), radial-gradient(at 80% 0%, #6666AD10 0px, transparent 50%), radial-gradient(at 0% 50%, #C2B86012 0px, transparent 50%), var(--surface-light);background-color:var(--surface-light);overflow:hidden;\">\n            <div style=\"pointer-events: none; background: var(--texture-grain); position: absolute; z-index: 1; opacity: 0.04; inset: 0\"></div>\n            \n            <div class=\"slide-content\" style=\"position:relative;z-index:10;padding:80px var(--space-6) 80px;display:flex;flex-direction:column;justify-content:center;height:100%;width:100%;box-sizing:border-box;overflow:hidden;\">\n                <div style=\"width:100%;display:flex;flex-direction:column;gap:12px;\">\n            <h2 style=\"font-family: Plus Jakarta Sans; font-size: 25px; font-weight: 600; line-height: 1.12; color: #0C0B07; margin: 0 0 12px; text-align: left; letter-spacing: -0.015em; overflow-wrap: break-word\">The Five Techniques</h2>\n            <div style=\"display:flex;flex-direction:column;gap:10px;width:100%;\"><div style=\"min-width:0;background:rgba(255,255,255,0.92);border:1px solid #CCCBC0;border-radius:0;padding:14px 14px 12px;box-sizing:border-box;display:flex;align-items:center;gap:12px;\">\n                <div style=\"width:34px;height:34px;border-radius:50%;background:#7C710C;color:#F7F6EA;display:flex;align-items:center;justify-content:center;font-family:Plus Jakarta Sans;font-size:13px;font-weight:900;flex-shrink:0;\">01</div>\n                <div style=\"flex:1;min-width:0;\">\n                    <div style=\"font-family:Plus Jakarta Sans;font-size:13px;font-weight:800;color:#0C0B07;margin-bottom:2px;\">Pattern Interrupt</div>\n                    <div style=\"font-family:Plus Jakarta Sans;font-size:11px;color:#44433A;line-height:1.4;\">Break the scroll. Make them stop. Then you have their attention.</div>\n                </div>\n            </div><div style=\"min-width:0;background:rgba(255,255,255,0.92);border:1px solid #CCCBC0;border-radius:0;padding:14px 14px 12px;box-sizing:border-box;display:flex;align-items:center;gap:12px;\">\n                <div style=\"width:34px;height:34px;border-radius:50%;background:#7C710C;color:#F7F6EA;display:flex;align-items:center;justify-content:center;font-family:Plus Jakarta Sans;font-size:13px;font-weight:900;flex-shrink:0;\">02</div>\n                <div style=\"flex:1;min-width:0;\">\n                    <div style=\"font-family:Plus Jakarta Sans;font-size:13px;font-weight:800;color:#0C0B07;margin-bottom:2px;\">Anchoring</div>\n                    <div style=\"font-family:Plus Jakarta Sans;font-size:11px;color:#44433A;line-height:1.4;\">Set the reference frame. The first number they see becomes the benchmark.</div>\n                </div>\n            </div><div style=\"min-width:0;background:rgba(255,255,255,0.92);border:1px solid #CCCBC0;border-radius:0;padding:14px 14px 12px;box-sizing:border-box;display:flex;align-items:center;gap:12px;\">\n                <div style=\"width:34px;height:34px;border-radius:50%;background:#7C710C;color:#F7F6EA;display:flex;align-items:center;justify-content:center;font-family:Plus Jakarta Sans;font-size:13px;font-weight:900;flex-shrink:0;\">03</div>\n                <div style=\"flex:1;min-width:0;\">\n                    <div style=\"font-family:Plus Jakarta Sans;font-size:13px;font-weight:800;color:#0C0B07;margin-bottom:2px;\">Commitment Escalation</div>\n                    <div style=\"font-family:Plus Jakarta Sans;font-size:11px;color:#44433A;line-height:1.4;\">Small yeses \u2192 big yeses. Every interaction is a micro-commitment.</div>\n                </div>\n            </div><div style=\"min-width:0;background:rgba(255,255,255,0.92);border:1px solid #CCCBC0;border-radius:0;padding:14px 14px 12px;box-sizing:border-box;display:flex;align-items:center;gap:12px;\">\n                <div style=\"width:34px;height:34px;border-radius:50%;background:#7C710C;color:#F7F6EA;display:flex;align-items:center;justify-content:center;font-family:Plus Jakarta Sans;font-size:13px;font-weight:900;flex-shrink:0;\">04</div>\n                <div style=\"flex:1;min-width:0;\">\n                    <div style=\"font-family:Plus Jakarta Sans;font-size:13px;font-weight:800;color:#0C0B07;margin-bottom:2px;\">Identity Framing</div>\n                    <div style=\"font-family:Plus Jakarta Sans;font-size:11px;color:#44433A;line-height:1.4;\">People don&#x27;t buy products. They buy the person they become.</div>\n                </div>\n            </div></div>\n            <p style=\"font-family:Plus Jakarta Sans;font-size:10.5px;color:#44433A;margin:4px 0 0;line-height:1.4;opacity:0.85;\">Automated 3-step compilation pipeline converting raw JSON specifications into production-ready carousel assets.</p>\n        </div>\n            </div>\n        </div>",
