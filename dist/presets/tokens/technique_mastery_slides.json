    "html": "<div style=\"position:relative;width:100%;height:100%;background:var(--surface-dark);background-color:var(--surface-dark);overflow:hidden;\">\n            <div style=\"inset: 0; position: absolute; pointer-events: none; z-index: 1; background: var(--texture-grain); opacity: 0.04\"></div>\n            \n            <div class=\"slide-content\" style=\"position:relative;z-index:10;padding:80px var(--space-6) 80px;display:flex;flex-direction:column;justify-content:center;height:100%;width:100%;box-sizing:border-box;overflow:hidden;\">\n                <div style=\"display:flex;flex-direction:column;gap:12px;width:100%;height:100%;justify-content:center;\">\n                    <div style=\"position:relative;width:100%;height:225px;border-radius: 0;overflow:hidden;background:transparent;box-sizing:border-box;\">\n                <img src=\"https://images.unsplash.com/photo-1519389950473-47ba0277781c?w=600\" alt=\"Technique 1: Pattern Interrupt\" style=\"display:block;width:100%;height:100%;object-fit: cover; object-position: center;filter: contrast(1.06) brightness(1.06);\" />\n                \n            </div>\n                    <div style=\"display:flex;flex-direction:column;justify-content:center;\">\n            <h2 style=\"font-family: Plus Jakarta Sans; font-size: 25px; font-weight: 600; line-height: 1.12; color: #EFEFE7; margin: 0 0 8px; text-align: left; letter-spacing: -0.015em; overflow-wrap: break-word\">Technique 1: Pattern Interrupt</h2>\n            <p style=\"font-family:Plus Jakarta Sans;font-size:12px;color:#CFCEC3;margin:0;line-height:1.45;opacity:0.9;\">Break the scroll pattern. Unexpected visuals, contradictory statements, or provocative questions force the brain to re-engage.</p>\n        </div>\n                </div>\n            </div>\n        </div>",
