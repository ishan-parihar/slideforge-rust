    "html": "<div style=\"position:relative;width:100%;height:100%;background:var(--surface-light);background-color:var(--surface-light);overflow:hidden;\">\n            <div style=\"position: absolute; inset: 0; background: var(--texture-grain); pointer-events: none; opacity: 0.04; z-index: 1\"></div>\n            \n            <div class=\"slide-content\" style=\"position:relative;z-index:10;padding:80px var(--space-6) 80px;display:flex;flex-direction:column;justify-content:center;height:100%;width:100%;box-sizing:border-box;overflow:hidden;\">\n                <div style=\"display:flex;flex-direction:column;gap:12px;width:100%;height:100%;justify-content:center;\">\n                    <div style=\"position:relative;width:100%;height:225px;border-radius: 0;overflow:hidden;background:transparent;box-sizing:border-box;\">\n                <img src=\"https://images.unsplash.com/photo-1451187580459-43490279c0fa?w=600\" alt=\"Breathe in for 4 counts\" style=\"display:block;width:100%;height:100%;object-fit: cover; object-position: center;filter: contrast(1.02) brightness(1.02);\" />\n                \n            </div>\n                    <div style=\"display:flex;flex-direction:column;justify-content:center;\">\n            <h2 style=\"font-family: Fraunces; font-size: 25px; font-weight: 600; line-height: 1.12; color: #070C0D; margin: 0 0 8px; text-align: left; letter-spacing: -0.015em; overflow-wrap: break-word\">Breathe in for 4 counts</h2>\n            <p style=\"font-family:Outfit;font-size:12px;color:#394545;margin:0;line-height:1.45;opacity:0.9;\">Let the breath arrive. Don&#x27;t force it. Simply notice the air entering your body. Count: one... two... three... four.</p>\n        </div>\n                </div>\n            </div>\n        </div>",
