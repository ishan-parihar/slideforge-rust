    "html": "<div style=\"position:relative;width:100%;height:100%;background:var(--surface-dark);background-color:var(--surface-dark);overflow:hidden;\">\n            <div style=\"z-index: 1; inset: 0; position: absolute; background: var(--texture-grain); opacity: 0.04; pointer-events: none\"></div>\n            \n            <div class=\"slide-content\" style=\"position:relative;z-index:10;padding:72px 44px;display:flex;flex-direction:column;justify-content:center;height:100%;width:100%;box-sizing:border-box;overflow:hidden;\">\n                <div style=\"width:100%;display:flex;flex-direction:column;gap:18px;\"><h2 style=\"font-family:Space Grotesk;font-size:30px;font-weight:900;color:#E9F1EC;margin:0;\">The Boy Scout Rule Checklist</h2><div style=\"display:flex;flex-direction:column;gap:10px;\"><div style=\"display:flex;gap:var(--space-1);align-items:flex-start;background:rgba(255,255,255,0.06);border:1px solid #203329;border-radius:0;padding:var(--space-1) 14px;\">\n                    <div style=\"width:24px;height:24px;border-radius:50%;background:#339C70;color:white;display:flex;align-items:center;justify-content:center;font-family:Space Grotesk;font-size:12px;font-weight:800;flex-shrink:0;\">1</div>\n                    <div style=\"font-family:Space Grotesk;font-size:var(--text-sm);font-weight:700;color:#E9F1EC;line-height:1.45;\">Rename vague or ambiguous variables</div>\n                </div><div style=\"display:flex;gap:var(--space-1);align-items:flex-start;background:rgba(255,255,255,0.06);border:1px solid #203329;border-radius:0;padding:var(--space-1) 14px;\">\n                    <div style=\"width:24px;height:24px;border-radius:50%;background:#339C70;color:white;display:flex;align-items:center;justify-content:center;font-family:Space Grotesk;font-size:12px;font-weight:800;flex-shrink:0;\">2</div>\n                    <div style=\"font-family:Space Grotesk;font-size:var(--text-sm);font-weight:700;color:#E9F1EC;line-height:1.45;\">Break complex conditions into named functions</div>\n                </div><div style=\"display:flex;gap:var(--space-1);align-items:flex-start;background:rgba(255,255,255,0.06);border:1px solid #203329;border-radius:0;padding:var(--space-1) 14px;\">\n                    <div style=\"width:24px;height:24px;border-radius:50%;background:#339C70;color:white;display:flex;align-items:center;justify-content:center;font-family:Space Grotesk;font-size:12px;font-weight:800;flex-shrink:0;\">3</div>\n                    <div style=\"font-family:Space Grotesk;font-size:var(--text-sm);font-weight:700;color:#E9F1EC;line-height:1.45;\">Delete dead code and outdated comments</div>\n                </div><div style=\"display:flex;gap:var(--space-1);align-items:flex-start;background:rgba(255,255,255,0.06);border:1px solid #203329;border-radius:0;padding:var(--space-1) 14px;\">\n                    <div style=\"width:24px;height:24px;border-radius:50%;background:#339C70;color:white;display:flex;align-items:center;justify-content:center;font-family:Space Grotesk;font-size:12px;font-weight:800;flex-shrink:0;\">4</div>\n                    <div style=\"font-family:Space Grotesk;font-size:var(--text-sm);font-weight:700;color:#E9F1EC;line-height:1.45;\">Write a unit test for the code you changed</div>\n                </div></div></div>\n            </div>\n        </div>",
