    "html": "<div style=\"position:relative;width:100%;height:100%;background:var(--surface-dark);background-color:var(--surface-dark);overflow:hidden;\">\n            <div style=\"opacity: 0.04; pointer-events: none; position: absolute; z-index: 1; background: var(--texture-grain); inset: 0\"></div>\n            \n            <div class=\"slide-content\" style=\"position:relative;z-index:10;padding:72px 44px;display:flex;flex-direction:column;justify-content:center;height:100%;width:100%;box-sizing:border-box;overflow:hidden;\">\n                <div style=\"width:100%;display:flex;flex-direction:column;gap:18px;\">\n            <h2 style=\"font-family:Space Grotesk;font-size:28px;font-weight:900;color:#E9F1EC;margin:0;line-height:1.08;\">Myth vs Fact</h2>\n            <div style=\"display:grid;grid-template-columns:1fr 1fr;gap:14px;\">\n                <div style=\"border-radius:0;padding:18px;background:rgba(255,255,255,0.06);border:1px solid #203329;\"><div style=\"font-family:Space Grotesk;font-size:11px;font-weight:800;color:#EF4444;margin-bottom:8px;\">PROBLEM</div><p style=\"font-family:Space Grotesk;font-size:var(--text-sm);color:#C6D1CB;line-height:1.45;margin:0;\">Exceptional developers write complex, clever code.</p></div>\n                <div style=\"border-radius:0;padding:18px;background:rgba(255,255,255,0.06);border:1px solid #203329;\"><div style=\"font-family:Space Grotesk;font-size:11px;font-weight:800;color:#339C70;margin-bottom:8px;\">SOLUTION</div><p style=\"font-family:Space Grotesk;font-size:var(--text-sm);color:#C6D1CB;line-height:1.45;margin:0;\">Exceptional developers write simple, readable code.</p></div>\n            </div>\n            <div style=\"display:grid;grid-template-columns:1fr;gap:10px;\"><div style=\"background:rgba(255,255,255,0.06);border:1px solid #203329;border-radius:0;padding:var(--space-2) 16px;box-sizing:border-box;\">\n                    <div style=\"display:flex;align-items:center;gap:10px;margin-bottom:8px;\"><div style=\"width:28px;height:28px;border-radius:0;background:#339C70;color:white;display:flex;align-items:center;justify-content:center;font-family:Space Grotesk;font-size:11px;font-weight:900;flex-shrink:0;\">C</div><div style=\"font-family:Space Grotesk;font-size:11px;font-weight:800;color:#339C70;text-transform:uppercase;\">01</div></div>\n                    <div style=\"font-family:Space Grotesk;font-size:15px;font-weight:800;color:#E9F1EC;line-height:1.2;margin-bottom:5px;\">Context</div>\n                    <div style=\"font-family:Space Grotesk;font-size:12px;color:#C6D1CB;line-height:1.45;\">Clever code is hard to read, debug, and maintain. Always prioritize clarity over cleverness.</div>\n                </div></div>\n        </div>\n            </div>\n        </div>",
